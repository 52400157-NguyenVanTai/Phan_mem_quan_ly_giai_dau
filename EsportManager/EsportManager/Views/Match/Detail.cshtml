@model EsportManager.Models.Match
@{
    ViewData["Title"] = "Trận Đấu";
    bool isLQ = Model.Tournament?.Game == EsportManager.Models.GameType.LienQuan;
    string ac = isLQ ? "var(--lq-gold)" : "var(--ff-orange)";
}
<div class="page-banner">
  <div class="page-banner-inner">
    <div class="breadcrumb"><a href="/Match">Lịch Thi Đấu</a><span>/</span>Chi Tiết Trận</div>
    <h1>
      <span style="color:@ac;">@(Model.Tournament?.Name ?? "Trận Đấu")</span>
      <span style="font-size:18px;color:var(--text-dim);margin-left:12px;">— @Model.RoundName</span>
    </h1>
  </div>
</div>

<div class="page-section">
  <div class="container">

    <!-- MATCH HERO -->
    <div class="game-frame mb-20">
      @if (Model.Status == EsportManager.Models.MatchStatus.Live)
      {
        <div style="margin-bottom:16px;"><span class="live-pip" style="font-size:13px;padding:6px 18px;"><div class="dot"></div>ĐANG DIỄN RA — LIVE</span></div>
      }
      <div style="display:flex;align-items:center;justify-content:center;gap:48px;flex-wrap:wrap;position:relative;z-index:1;">
        <!-- TEAM 1 -->
        <div style="text-align:center;flex:1;min-width:140px;">
          <div style="font-size:56px;margin-bottom:10px;filter:drop-shadow(0 0 20px @ac);">@(isLQ ? "⚔️" : "🔥")</div>
          <div class="match-hero-team" style="color:@(Model.WinnerId == Model.Team1Id ? ac : "var(--text-white)")">
            [@(Model.Team1?.Tag ?? "???")]<br/>@(Model.Team1?.Name ?? "TBD")
          </div>
          @if (Model.WinnerId == Model.Team1Id)
          {
            <div style="margin-top:8px;"><span style="background:@ac;color:var(--bg-void);padding:4px 14px;border-radius:12px;font-family:'Rajdhani',sans-serif;font-weight:700;font-size:13px;">🏆 WINNER</span></div>
          }
        </div>

        <!-- SCORE / VS -->
        <div style="text-align:center;min-width:120px;">
          @if (Model.Status == EsportManager.Models.MatchStatus.Completed || Model.Status == EsportManager.Models.MatchStatus.Live)
          {
            <div class="match-hero-score" style="color:@(Model.Status == EsportManager.Models.MatchStatus.Live ? "var(--live-red)" : "var(--text-white)");">@Model.Team1Score — @Model.Team2Score</div>
          }
          else
          {
            <div style="font-family:'Rajdhani',sans-serif;font-size:48px;font-weight:700;color:var(--text-muted);">VS</div>
            <div style="font-size:14px;color:var(--text-dim);margin-top:8px;">
              <i class="far fa-clock" style="margin-right:6px;"></i>@Model.ScheduledAt.ToString("HH:mm — dd/MM/yyyy")
            </div>
          }
          <div style="margin-top:12px;">
            <span class="chip chip-cyan">@Model.RoundName</span>
            @if (!string.IsNullOrEmpty(Model.Tournament?.MatchFormat.ToString()))
            {
              <span class="chip @(isLQ?"chip-lq":"chip-ff")" style="margin-left:6px;">@Model.Tournament?.MatchFormat</span>
            }
          </div>
        </div>

        <!-- TEAM 2 -->
        <div style="text-align:center;flex:1;min-width:140px;">
          <div style="font-size:56px;margin-bottom:10px;filter:drop-shadow(0 0 20px @ac);">@(isLQ ? "⚔️" : "🔥")</div>
          <div class="match-hero-team" style="color:@(Model.WinnerId == Model.Team2Id ? ac : "var(--text-white)")">
            [@(Model.Team2?.Tag ?? "???")]<br/>@(Model.Team2?.Name ?? "TBD")
          </div>
          @if (Model.WinnerId == Model.Team2Id)
          {
            <div style="margin-top:8px;"><span style="background:@ac;color:var(--bg-void);padding:4px 14px;border-radius:12px;font-family:'Rajdhani',sans-serif;font-weight:700;font-size:13px;">🏆 WINNER</span></div>
          }
        </div>
      </div>
    </div>

    <div class="page-layout">
      <div>
        <!-- MATCH INFO -->
        <div class="panel mb-20">
          <div class="panel-header"><span class="panel-title">📋 Thông Tin Trận Đấu</span></div>
          <div class="panel-body">
            <div class="info-row"><i class="fas fa-calendar"></i><span class="info-lbl">Thời Gian:</span><span class="info-val">@Model.ScheduledAt.ToString("HH:mm — dd/MM/yyyy")</span></div>
            <div class="info-row"><i class="fas fa-flag"></i><span class="info-lbl">Trạng Thái:</span>
              <span class="chip @(Model.Status==EsportManager.Models.MatchStatus.Live?"chip-red":Model.Status==EsportManager.Models.MatchStatus.Completed?"chip-green":Model.Status==EsportManager.Models.MatchStatus.Scheduled?"chip-cyan":"chip-warn")">
                @Model.Status.ToString()
              </span>
            </div>
            <div class="info-row"><i class="fas fa-sitemap"></i><span class="info-lbl">Vòng:</span><span class="info-val">@Model.RoundName</span></div>
            @if (!string.IsNullOrEmpty(Model.RoomId))
            {
              <div class="info-row"><i class="fas fa-door-open"></i><span class="info-lbl">Room ID:</span>
                <span style="background:var(--bg-surface);border:1px solid var(--cyan-border);padding:4px 12px;border-radius:var(--radius-sm);font-family:'Rajdhani',sans-serif;font-weight:700;color:var(--cyan);font-size:16px;letter-spacing:2px;">@Model.RoomId</span>
              </div>
            }
            @if (!string.IsNullOrEmpty(Model.RoomPassword))
            {
              <div class="info-row"><i class="fas fa-key"></i><span class="info-lbl">Mật Khẩu:</span>
                <span style="background:var(--bg-surface);border:1px solid rgba(255,193,7,0.3);padding:4px 12px;border-radius:var(--radius-sm);font-family:'Rajdhani',sans-serif;font-weight:700;color:var(--lq-gold);">@Model.RoomPassword</span>
              </div>
            }
            @if (!string.IsNullOrEmpty(Model.StreamUrl))
            {
              <div class="info-row"><i class="fas fa-play-circle"></i><span class="info-lbl">Stream:</span>
                <a href="@Model.StreamUrl" target="_blank" class="btn btn-danger btn-sm"><i class="fas fa-broadcast-tower"></i> Xem Live</a>
              </div>
            }
            @if (!string.IsNullOrEmpty(Model.Notes))
            {
              <div class="info-row"><i class="fas fa-sticky-note"></i><span class="info-lbl">Ghi Chú:</span><span class="info-val">@Model.Notes</span></div>
            }
          </div>
        </div>

        <!-- CONFIRMATION STATUS -->
        <div class="panel mb-20">
          <div class="panel-header"><span class="panel-title">✅ Xác Nhận Kết Quả</span></div>
          <div class="panel-body">
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px;">
              <div style="padding:16px;background:@(Model.Team1Confirmed?"rgba(0,230,118,0.08)":"var(--bg-surface)");border:1px solid @(Model.Team1Confirmed?"rgba(0,230,118,0.3)":"var(--border)");border-radius:var(--radius);text-align:center;">
                <div style="font-size:28px;margin-bottom:8px;">@(Model.Team1Confirmed ? "✅" : "⏳")</div>
                <div style="font-family:'Rajdhani',sans-serif;font-weight:700;font-size:15px;">@(Model.Team1?.Name ?? "Team 1")</div>
                <div style="font-size:12px;color:@(Model.Team1Confirmed?"var(--success)":"var(--text-dim)");font-weight:600;margin-top:4px;">@(Model.Team1Confirmed ? "Đã xác nhận" : "Chờ xác nhận")</div>
              </div>
              <div style="padding:16px;background:@(Model.Team2Confirmed?"rgba(0,230,118,0.08)":"var(--bg-surface)");border:1px solid @(Model.Team2Confirmed?"rgba(0,230,118,0.3)":"var(--border)");border-radius:var(--radius);text-align:center;">
                <div style="font-size:28px;margin-bottom:8px;">@(Model.Team2Confirmed ? "✅" : "⏳")</div>
                <div style="font-family:'Rajdhani',sans-serif;font-weight:700;font-size:15px;">@(Model.Team2?.Name ?? "Team 2")</div>
                <div style="font-size:12px;color:@(Model.Team2Confirmed?"var(--success)":"var(--text-dim)");font-weight:600;margin-top:4px;">@(Model.Team2Confirmed ? "Đã xác nhận" : "Chờ xác nhận")</div>
              </div>
            </div>
            @if (Model.Status != EsportManager.Models.MatchStatus.Completed)
            {
              <div style="background:rgba(255,234,0,0.05);border:1px solid rgba(255,234,0,0.2);border-radius:var(--radius-sm);padding:10px 14px;font-size:12px;color:var(--warning);">
                <i class="fas fa-exclamation-triangle" style="margin-right:6px;"></i>Cả 2 đội cần xác nhận kết quả mới tính điểm ELO
              </div>
            }
          </div>
        </div>

        <!-- SUBMIT RESULT -->
        @if (Model.Status != EsportManager.Models.MatchStatus.Completed)
        {
          <div class="panel mb-20">
            <div class="panel-header"><span class="panel-title">📤 Nhập Kết Quả Trận Đấu</span></div>
            <div class="panel-body">
              <form method="post" action="/Match/SubmitResult">
                <input type="hidden" name="matchId" value="@Model.Id" />
                <div style="display:grid;grid-template-columns:1fr 40px 1fr;gap:12px;align-items:end;margin-bottom:16px;">
                  <div class="form-group" style="margin:0;">
                    <label class="form-label">@(Model.Team1?.Name ?? "TEAM 1")</label>
                    <input class="form-input" type="number" name="t1s" min="0" max="5" value="0" style="text-align:center;font-family:'Rajdhani',sans-serif;font-size:28px;font-weight:700;color:var(--text-white);" />
                  </div>
                  <div style="text-align:center;padding-bottom:10px;font-family:'Rajdhani',sans-serif;font-size:20px;color:var(--text-muted);">—</div>
                  <div class="form-group" style="margin:0;">
                    <label class="form-label">@(Model.Team2?.Name ?? "TEAM 2")</label>
                    <input class="form-input" type="number" name="t2s" min="0" max="5" value="0" style="text-align:center;font-family:'Rajdhani',sans-serif;font-size:28px;font-weight:700;color:var(--text-white);" />
                  </div>
                </div>
                <div class="form-group">
                  <label class="form-label">Link Bằng Chứng (Screenshot/Video)</label>
                  <input class="form-input" placeholder="https://imgur.com/... hoặc YouTube link" />
                </div>
                <button type="submit" class="btn btn-cyan btn-full"><i class="fas fa-paper-plane"></i> GỬI KẾT QUẢ</button>
              </form>
            </div>
          </div>
        }

        <!-- GAME SPECIFIC (LQ role players / FF squad) -->
        <div class="panel">
          <div class="panel-header">
            <span class="panel-title">@(isLQ ? "⚔ Lineup Liên Quân" : "🔥 Squad Free Fire")</span>
          </div>
          <div class="panel-body">
            @if (isLQ)
            {
              var roles = new[] { "Jungler", "Support", "Carry ADC", "Mid", "Roamer" };
              <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                @foreach (var role in roles)
                {
                  <div style="display:flex;align-items:center;gap:10px;padding:10px;background:var(--bg-surface);border:1px solid var(--border);border-radius:var(--radius-sm);">
                    <div style="width:8px;height:8px;background:var(--lq-gold);border-radius:50%;flex-shrink:0;"></div>
                    <div>
                      <div style="font-size:10px;color:var(--text-dim);text-transform:uppercase;letter-spacing:1px;">@role</div>
                      <div style="font-weight:600;font-size:13px;color:var(--text-dim);">— TBD —</div>
                    </div>
                  </div>
                }
              </div>
            }
            else
            {
              var roles = new[] { "IGL (Leader)", "Fragger", "Support", "Sniper", "Scout" };
              <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                @foreach (var role in roles)
                {
                  <div style="display:flex;align-items:center;gap:10px;padding:10px;background:var(--bg-surface);border:1px solid var(--border);border-radius:var(--radius-sm);">
                    <div style="width:8px;height:8px;background:var(--ff-orange);border-radius:50%;flex-shrink:0;"></div>
                    <div>
                      <div style="font-size:10px;color:var(--text-dim);text-transform:uppercase;letter-spacing:1px;">@role</div>
                      <div style="font-weight:600;font-size:13px;color:var(--text-dim);">— TBD —</div>
                    </div>
                  </div>
                }
              </div>
            }
          </div>
        </div>
      </div>

      <!-- SIDEBAR -->
      <div>
        @if (Model.Tournament != null)
        {
          <div class="widget mb-20">
            <div class="widget-head" style="color:@ac;">🏆 Giải Đấu</div>
            <div class="widget-body">
              <div style="font-size:18px;text-align:center;margin-bottom:10px;">@(isLQ ? "⚔️" : "🔥")</div>
              <div style="font-family:'Rajdhani',sans-serif;font-weight:700;font-size:15px;text-align:center;margin-bottom:8px;line-height:1.3;">@Model.Tournament.Name</div>
              <div style="text-align:center;margin-bottom:14px;"><span class="chip @(isLQ?"chip-lq":"chip-ff")">@Model.Tournament.MatchFormat</span></div>
              <a href="/Tournament/Detail/@Model.TournamentId" class="btn @(isLQ?"btn-lq":"btn-ff") btn-full btn-sm">Xem Giải Đấu</a>
            </div>
          </div>
        }

        <!-- CHAT -->
        <div class="widget mb-20">
          <div class="widget-head">💬 Match Chat</div>
          <div style="padding:14px;">
            <div style="height:200px;overflow-y:auto;background:var(--bg-surface);border:1px solid var(--border);border-radius:var(--radius-sm);padding:12px;margin-bottom:10px;">
              <div style="font-size:12px;margin-bottom:8px;"><b style="color:var(--cyan);">[Admin]:</b> <span style="color:var(--text-dim);">Good luck both teams! GG WP 🎮</span></div>
              <div style="font-size:12px;margin-bottom:8px;"><b style="color:var(--lq-gold);">[@(Model.Team1?.Tag??"T1")]:</b> <span style="color:var(--text-dim);">Ready! 🔥</span></div>
              <div style="font-size:12px;"><b style="color:var(--ff-orange);">[@(Model.Team2?.Tag??"T2")]:</b> <span style="color:var(--text-dim);">GL HF! ⚔</span></div>
            </div>
            <div style="display:flex;gap:8px;">
              <input class="form-input" placeholder="Nhắn tin..." style="flex:1;" />
              <button class="btn btn-cyan btn-sm" style="flex-shrink:0;"><i class="fas fa-paper-plane"></i></button>
            </div>
          </div>
        </div>

        <!-- TEAM QUICK LINKS -->
        <div class="widget">
          <div class="widget-head">🛡 Các Đội</div>
          <div class="widget-body">
            @if (Model.Team1 != null)
            {
              <a href="/Team/Detail/@Model.Team1Id" style="display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid var(--border);color:var(--text-white);">
                <div style="font-size:24px;">@(isLQ?"⚔":"🔥")</div>
                <div>
                  <div style="font-weight:700;">@Model.Team1.Name</div>
                  <div style="font-size:11px;color:var(--text-dim);">@Model.Team1.Wins W – @Model.Team1.Losses L</div>
                </div>
                <div style="margin-left:auto;font-family:'Rajdhani',sans-serif;font-weight:700;color:var(--cyan);">@Model.Team1.Points ELO</div>
              </a>
            }
            @if (Model.Team2 != null)
            {
              <a href="/Team/Detail/@Model.Team2Id" style="display:flex;align-items:center;gap:12px;padding:10px 0;color:var(--text-white);">
                <div style="font-size:24px;">@(isLQ?"⚔":"🔥")</div>
                <div>
                  <div style="font-weight:700;">@Model.Team2.Name</div>
                  <div style="font-size:11px;color:var(--text-dim);">@Model.Team2.Wins W – @Model.Team2.Losses L</div>
                </div>
                <div style="margin-left:auto;font-family:'Rajdhani',sans-serif;font-weight:700;color:var(--cyan);">@Model.Team2.Points ELO</div>
              </a>
            }
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
