@model EsportManager.Models.User
@{ViewData["Title"] = "Hồ Sơ — " + Model.IngameName; Layout = "~/Views/Shared/_Layout.cshtml";
  var teams = ViewBag.Teams as List<EsportManager.Models.Team>; var history = ViewBag.MatchHistory as List<EsportManager.Models.Match>;}
<div class="profile-hero">
  <div class="container" style="position:relative;z-index:1;">
    <div style="display:flex;align-items:flex-start;gap:28px;flex-wrap:wrap;">
      <div class="profile-avatar-hex">👤</div>
      <div style="flex:1;min-width:200px;">
        <div class="profile-name">@Model.IngameName
          @if (Model.IsVerified){<span style="background:rgba(0,230,118,0.15);border:1px solid rgba(0,230,118,0.3);color:var(--success);padding:3px 10px;border-radius:10px;font-size:11px;font-weight:700;margin-left:8px;vertical-align:middle;">✓ VERIFIED</span>}
          @if (Model.IsAdmin){<span style="background:rgba(255,193,7,0.15);border:1px solid rgba(255,193,7,0.3);color:var(--lq-gold);padding:3px 10px;border-radius:10px;font-size:11px;font-weight:700;margin-left:6px;vertical-align:middle;">⚙ ADMIN</span>}
        </div>
        <div style="color:var(--text-dim);font-size:14px;margin:6px 0;">@Model.Email · <span style="color:var(--text-muted);">@@</span>@Model.Username</div>
        <div style="display:flex;flex-wrap:wrap;gap:6px;margin-top:8px;">
          @if (!string.IsNullOrEmpty(Model.GameUID_LQ)){<div class="uid-display">⚔ LQ: <span>@Model.GameUID_LQ</span></div>}
          @if (!string.IsNullOrEmpty(Model.GameUID_FF)){<div class="uid-display">🔥 FF: <span>@Model.GameUID_FF</span></div>}
          <span class="rank-badge-display rank-lq">⚔ @Model.Rank_LQ</span>
          <span class="rank-badge-display rank-ff">🔥 @Model.Rank_FF</span>
        </div>
      </div>
      <div style="display:flex;gap:24px;flex-shrink:0;flex-wrap:wrap;">
        @{var ps=new[]{(Model.TotalWins.ToString(),"Wins","var(--success)"),(Model.TotalLosses.ToString(),"Losses","var(--danger)"),(teams?.Count.ToString()??"0","Đội","var(--cyan)")};}
        @foreach(var s in ps){<div style="text-align:center;"><div style="font-family:'Rajdhani',sans-serif;font-size:28px;font-weight:700;color:@s.Item3;">@s.Item1</div><div style="font-size:11px;color:var(--text-dim);text-transform:uppercase;letter-spacing:1px;">@s.Item2</div></div>}
      </div>
    </div>
  </div>
</div>

<div class="page-section">
  <div class="container">
    <div class="page-layout">
      <div>
        <div class="tabs-bar">
          <button class="tab-btn active" onclick="switchTab('pf-teams',this)">🛡 Đội Của Tôi</button>
          <button class="tab-btn" onclick="switchTab('pf-history',this)">⚡ Lịch Sử</button>
          <button class="tab-btn" onclick="switchTab('pf-edit',this)">✏ Chỉnh Sửa</button>
        </div>

        <div id="pf-teams" class="tab-pane active">
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
            @if (teams != null && teams.Any())
            {
              @foreach (var t in teams)
              {
                bool isLQ = t.PrimaryGame == EsportManager.Models.GameType.LienQuan;
                <a href="/Team/Detail/@t.Id" class="team-card @(isLQ?"lq-team":"ff-team")">
                  <div class="team-logo-hex">@(isLQ?"⚔":"🔥")</div>
                  <div class="team-name-display">@t.Name</div>
                  <div class="team-tag-display">[@t.Tag]</div>
                  <div style="margin-bottom:10px;"><span class="chip @(isLQ?"chip-lq":"chip-ff")" style="font-size:10px;">👑 CAPTAIN</span></div>
                  <div class="team-stats-row">
                    <div class="team-stat-item"><div class="val val-win">@t.Wins</div><div class="lbl">Win</div></div>
                    <div class="team-stat-item"><div class="val val-loss">@t.Losses</div><div class="lbl">Loss</div></div>
                    <div class="team-stat-item"><div class="val val-pts">@t.Points</div><div class="lbl">ELO</div></div>
                  </div>
                </a>
              }
            }
            else
            {
              <div style="grid-column:span 2;text-align:center;padding:40px;color:var(--text-dim);">
                <div style="font-size:40px;margin-bottom:12px;">🛡</div>
                <p>Bạn chưa có đội nào.</p>
                <a href="/Team/Create" class="btn btn-cyan" style="margin-top:12px;display:inline-flex;">+ Lập Đội Ngay</a>
              </div>
            }
          </div>
          <a href="/Team/Create" class="btn btn-outline" style="margin-top:16px;display:inline-flex;"><i class="fas fa-plus"></i> Lập Đội Mới</a>
        </div>

        <div id="pf-history" class="tab-pane">
          @if (history != null && history.Any())
          {
            @foreach (var m in history)
            {
              <div class="match-card">
                <div class="match-teams">
                  <div class="match-team"><div class="match-team-tag">[@(m.Team1?.Tag??"???")]</div><div class="match-team-name @(m.WinnerId==m.Team1Id?"winner":"")">@(m.Team1?.Name??"TBD")</div></div>
                  <div class="match-center"><div class="match-score-display">@m.Team1Score — @m.Team2Score</div><div class="match-round">@m.RoundName</div></div>
                  <div class="match-team"><div class="match-team-tag">[@(m.Team2?.Tag??"???")]</div><div class="match-team-name @(m.WinnerId==m.Team2Id?"winner":"")">@(m.Team2?.Name??"TBD")</div></div>
                </div>
                <div style="font-size:12px;color:var(--text-dim);">@m.ScheduledAt.ToString("dd/MM/yyyy")</div>
              </div>
            }
          }
          else { <div style="text-align:center;padding:40px;color:var(--text-dim);">Chưa có lịch sử thi đấu</div> }
        </div>

        <div id="pf-edit" class="tab-pane">
          <div class="panel">
            <div class="panel-header"><span class="panel-title">✏ Chỉnh Sửa Hồ Sơ</span></div>
            <div class="panel-body">
              <div class="form-group"><label class="form-label">Tên Ingame</label><input class="form-input" value="@Model.IngameName" /></div>
              <div class="grid-2-form">
                <div class="form-group"><label class="form-label">UID Liên Quân</label><input class="form-input" value="@Model.GameUID_LQ" /></div>
                <div class="form-group"><label class="form-label">UID Free Fire</label><input class="form-input" value="@Model.GameUID_FF" /></div>
                <div class="form-group"><label class="form-label">Rank LQ</label><select class="form-input"><option>@Model.Rank_LQ</option><option>Thách Đấu</option><option>Cao Thủ</option><option>Kim Cương</option></select></div>
                <div class="form-group"><label class="form-label">Rank FF</label><select class="form-input"><option>@Model.Rank_FF</option><option>Grandmaster</option><option>Heroic</option><option>Diamond</option></select></div>
              </div>
              <button type="button" class="btn btn-cyan"><i class="fas fa-save"></i> Lưu Thay Đổi</button>
            </div>
          </div>
        </div>
      </div>

      <div>
        <div class="widget mb-20">
          <div class="widget-head">📊 Thống Kê</div>
          <div class="widget-body">
            @{var ws=new[]{("Rank Liên Quân",Model.Rank_LQ,"var(--lq-gold)"),("Rank Free Fire",Model.Rank_FF,"var(--ff-orange)"),("Trạng thái",Model.IsVerified?"Verified":"Unverified",Model.IsVerified?"var(--success)":"var(--danger)"),("Tham gia từ",Model.CreatedAt.ToString("MM/yyyy"),"var(--text-dim)")};}
            @foreach(var w in ws){<div style="display:flex;justify-content:space-between;font-size:13px;padding:9px 0;border-top:1px solid rgba(0,229,255,0.05);"><span style="color:var(--text-dim);">@w.Item1</span><b style="color:@w.Item3;">@w.Item2</b></div>}
          </div>
        </div>
        <a href="/Tournament?status=Registration" class="btn btn-lq btn-full mb-12"><i class="fas fa-gamepad"></i> Đăng Ký Giải LQ</a>
        <a href="/Tournament?status=Registration&game=FreeFire" class="btn btn-ff btn-full"><i class="fas fa-fire"></i> Đăng Ký Giải FF</a>
      </div>
    </div>
  </div>
</div>
