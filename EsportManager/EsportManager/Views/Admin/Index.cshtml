@* Admin/Index.cshtml *@
@{ViewData["Title"]="Admin Dashboard"; Layout = null;
  var recentMatches = ViewBag.RecentMatches as List<EsportManager.Models.Match>;}
<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="utf-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>Admin — EsportArena</title>
  <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;600;700&family=Exo+2:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
  <link rel="stylesheet" href="~/css/site.css"/>
</head>
<body style="margin:0;">
<div class="admin-layout">
  <!-- SIDEBAR -->
  <aside class="admin-sidebar">
    <div class="sidebar-logo">
      <div class="logo-title">ESPORT<span>ARENA</span></div>
      <div class="admin-badge">ADMIN PANEL</div>
    </div>
    <div class="sidebar-section">
      <div class="sidebar-section-label">Overview</div>
      <a href="/Admin" class="sidebar-link active"><i class="fas fa-tachometer-alt"></i> Dashboard</a>
    </div>
    <div class="sidebar-section">
      <div class="sidebar-section-label">Quản Lý</div>
      <a href="/Admin/Tournaments" class="sidebar-link"><i class="fas fa-trophy"></i> Giải Đấu</a>
      <a href="/Admin/Registrations" class="sidebar-link live-link"><i class="fas fa-clipboard-list"></i> Duyệt Đăng Ký <span class="badge">@ViewBag.PendingReg</span></a>
      <a href="/Admin/Users" class="sidebar-link"><i class="fas fa-users"></i> Người Dùng</a>
      <a href="/Match" class="sidebar-link @(ViewBag.LiveMatches>0?"live-link":"")"><i class="fas fa-gamepad"></i> Trận Đấu @if(ViewBag.LiveMatches>0){<span class="badge">LIVE</span>}</a>
    </div>
    <div class="sidebar-section">
      <div class="sidebar-section-label">Game</div>
      <a href="/Tournament?game=LienQuan" class="sidebar-link"><i style="color:var(--lq-gold);">⚔</i> Liên Quân</a>
      <a href="/Tournament?game=FreeFire" class="sidebar-link"><i style="color:var(--ff-orange);">🔥</i> Free Fire</a>
      <a href="/Ranking" class="sidebar-link"><i class="fas fa-chart-bar"></i> Ranking ELO</a>
    </div>
    <div class="sidebar-section" style="margin-top:auto;">
      <a href="/" class="sidebar-link"><i class="fas fa-home"></i> Về Trang Chủ</a>
      <a href="/Account/Logout" class="sidebar-link" style="color:var(--danger);"><i class="fas fa-sign-out-alt"></i> Đăng Xuất</a>
    </div>
  </aside>

  <!-- MAIN -->
  <main class="admin-main">
    <div class="admin-topbar">
      <div>
        <div class="admin-page-title">Dashboard</div>
        <div class="admin-page-subtitle">Chào mừng trở lại! Đây là tổng quan hệ thống EsportArena VN 👾</div>
      </div>
      <div style="font-size:12px;color:var(--text-dim);"><i class="far fa-clock" style="margin-right:6px;color:var(--cyan);"></i>@DateTime.Now.ToString("HH:mm — dd/MM/yyyy")</div>
    </div>

    <!-- STAT CARDS -->
    <div class="stat-grid">
      <div class="stat-box sb-cyan"><div class="stat-icon-box sib-cyan"><i class="fas fa-users"></i></div><div><div class="stat-val" data-count="@ViewBag.TotalUsers">@ViewBag.TotalUsers</div><div class="stat-lbl">Game Thủ</div></div></div>
      <div class="stat-box sb-lq"><div class="stat-icon-box sib-lq">⚔</div><div><div class="stat-val" data-count="@ViewBag.TotalTournaments">@ViewBag.TotalTournaments</div><div class="stat-lbl">Giải Đấu</div></div></div>
      <div class="stat-box sb-ff"><div class="stat-icon-box sib-ff"><i class="fas fa-clipboard-list"></i></div><div><div class="stat-val" data-count="@ViewBag.PendingReg">@ViewBag.PendingReg</div><div class="stat-lbl">Chờ Duyệt</div></div></div>
      <div class="stat-box sb-green"><div class="stat-icon-box sib-green"><i class="fas fa-broadcast-tower"></i></div><div><div class="stat-val" data-count="@ViewBag.LiveMatches">@ViewBag.LiveMatches</div><div class="stat-lbl">Đang LIVE</div></div></div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 340px;gap:20px;">
      <!-- RECENT MATCHES -->
      <div class="panel">
        <div class="panel-header">
          <span class="panel-title">⚡ Trận Đấu Gần Đây</span>
          <a href="/Match" style="font-size:12px;color:var(--cyan);">Xem tất cả →</a>
        </div>
        <table class="admin-table">
          <thead><tr><th>Game</th><th>Team 1</th><th>Score</th><th>Team 2</th><th>Status</th><th>Vòng</th><th></th></tr></thead>
          <tbody>
            @if (recentMatches != null)
            {
              @foreach (var m in recentMatches)
              {
                bool isLQ = m.Tournament?.Game == EsportManager.Models.GameType.LienQuan;
                <tr>
                  <td style="font-size:18px;">@(isLQ?"⚔️":"🔥")</td>
                  <td style="font-weight:700;">@(m.Team1?.Name??"TBD")</td>
                  <td><span style="font-family:'Rajdhani',sans-serif;font-weight:700;color:var(--text-white);">@m.Team1Score — @m.Team2Score</span></td>
                  <td style="font-weight:700;">@(m.Team2?.Name??"TBD")</td>
                  <td><span class="chip @(m.Status==EsportManager.Models.MatchStatus.Live?"chip-red":m.Status==EsportManager.Models.MatchStatus.Completed?"chip-green":m.Status==EsportManager.Models.MatchStatus.Scheduled?"chip-cyan":"chip-warn")">@m.Status</span></td>
                  <td style="color:var(--text-dim);font-size:12px;">@m.RoundName</td>
                  <td><a href="/Match/Detail/@m.Id" class="btn btn-outline btn-sm" style="font-size:11px;">Detail</a></td>
                </tr>
              }
            }
          </tbody>
        </table>
      </div>

      <!-- QUICK ACTIONS & STATS -->
      <div>
        <div class="panel mb-20">
          <div class="panel-header"><span class="panel-title">⚡ Thao Tác Nhanh</span></div>
          <div class="panel-body" style="display:flex;flex-direction:column;gap:10px;">
            <a href="/Tournament/Create" style="display:flex;align-items:center;gap:12px;padding:12px;background:rgba(0,229,255,0.06);border:1px solid var(--border);border-radius:var(--radius-sm);color:var(--text-white);transition:all 0.2s;">
              <span style="font-size:20px;">🏆</span>
              <div><div style="font-weight:700;font-size:13px;">Tạo Giải Đấu Mới</div><div style="font-size:11px;color:var(--text-dim);">LQ hoặc Free Fire</div></div>
            </a>
            <a href="/Admin/Registrations" style="display:flex;align-items:center;gap:12px;padding:12px;background:@((int)ViewBag.PendingReg>0?"rgba(255,234,0,0.06)":"rgba(0,0,0,0.1)");border:1px solid @((int)ViewBag.PendingReg>0?"rgba(255,234,0,0.3)":"var(--border)");border-radius:var(--radius-sm);color:var(--text-white);">
              <span style="font-size:20px;">📋</span>
              <div><div style="font-weight:700;font-size:13px;">Duyệt Đăng Ký</div><div style="font-size:11px;color:var(--text-dim);">@ViewBag.PendingReg đơn đang chờ</div></div>
              @if ((int)ViewBag.PendingReg > 0) { <span class="chip chip-warn" style="margin-left:auto;">@ViewBag.PendingReg</span> }
            </a>
            <a href="/Admin/Users" style="display:flex;align-items:center;gap:12px;padding:12px;background:rgba(0,0,0,0.1);border:1px solid var(--border);border-radius:var(--radius-sm);color:var(--text-white);">
              <span style="font-size:20px;">👥</span>
              <div><div style="font-weight:700;font-size:13px;">Quản Lý Users</div><div style="font-size:11px;color:var(--text-dim);">@ViewBag.TotalUsers tài khoản</div></div>
            </a>
          </div>
        </div>

        <div class="panel">
          <div class="panel-header"><span class="panel-title">📊 Trạng Thái Giải</span></div>
          <div class="panel-body">
            @{
              var statuses = new[] {
                ("Ongoing", "Đang Diễn Ra", "var(--danger)"),
                ("Registration", "Đang Đăng Ký", "var(--success)"),
                ("Upcoming", "Sắp Diễn Ra", "var(--cyan)"),
                ("Completed", "Đã Kết Thúc", "var(--text-muted)")
              };
            }
            @foreach (var s in statuses)
            {
              if (Enum.TryParse<EsportManager.Models.TournamentStatus>(s.Item1, out var st))
              {
                int cnt = EsportManager.Services.MockData.Tournaments.Count(t => t.Status == st);
                int pct = EsportManager.Services.MockData.Tournaments.Count > 0 ? cnt * 100 / EsportManager.Services.MockData.Tournaments.Count : 0;
                <div style="margin-bottom:12px;">
                  <div style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:5px;"><span style="color:var(--text-dim);">@s.Item2</span><b style="color:@s.Item3;">@cnt</b></div>
                  <div class="elo-progress"><div style="height:100%;width:@pct%;background:@s.Item3;border-radius:3px;transition:width 1s;"></div></div>
                </div>
              }
            }
          </div>
        </div>
      </div>
    </div>
  </main>
</div>
<script src="~/js/site.js"></script>
</body></html>
