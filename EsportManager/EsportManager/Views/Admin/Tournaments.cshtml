@model List<EsportManager.Models.Tournament>
@{ViewData["Title"]="Admin – Giải Đấu"; Layout=null;}
<!DOCTYPE html><html lang="vi"><head><meta charset="utf-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>Admin Tournaments — EsportArena</title>
<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;600;700&family=Exo+2:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
<link rel="stylesheet" href="~/css/site.css"/></head>
<body style="margin:0;">
<div class="admin-layout">
  <aside class="admin-sidebar">
    <div class="sidebar-logo"><div class="logo-title">ESPORT<span>ARENA</span></div><div class="admin-badge">ADMIN PANEL</div></div>
    <div class="sidebar-section">
      <a href="/Admin" class="sidebar-link"><i class="fas fa-tachometer-alt"></i> Dashboard</a>
      <a href="/Admin/Tournaments" class="sidebar-link active"><i class="fas fa-trophy"></i> Giải Đấu</a>
      <a href="/Admin/Registrations" class="sidebar-link"><i class="fas fa-clipboard-list"></i> Duyệt Đăng Ký</a>
      <a href="/Admin/Users" class="sidebar-link"><i class="fas fa-users"></i> Người Dùng</a>
      <a href="/Match" class="sidebar-link"><i class="fas fa-gamepad"></i> Trận Đấu</a>
    </div>
    <div class="sidebar-section"><a href="/" class="sidebar-link"><i class="fas fa-home"></i> Trang Chủ</a><a href="/Account/Logout" class="sidebar-link" style="color:var(--danger);"><i class="fas fa-sign-out-alt"></i> Đăng Xuất</a></div>
  </aside>
  <main class="admin-main">
    <div class="admin-topbar">
      <div><div class="admin-page-title">🏆 Quản Lý Giải Đấu</div><div class="admin-page-subtitle">Tổng: <b style="color:var(--cyan)">@Model.Count</b> giải đấu</div></div>
      <a href="/Tournament/Create" class="btn btn-cyan btn-sm"><i class="fas fa-plus"></i> Tạo Giải Mới</a>
    </div>
    <div class="panel">
      <div class="panel-header"><span class="panel-title">DANH SÁCH GIẢI ĐẤU</span></div>
      <table class="admin-table">
        <thead><tr><th>Tên Giải</th><th>Game</th><th>Format</th><th>Đội</th><th>Prize Pool</th><th>Trạng Thái</th><th>Thời Gian</th><th>Thao Tác</th></tr></thead>
        <tbody>
          @foreach(var t in Model)
          {
            bool isLQ=t.Game==EsportManager.Models.GameType.LienQuan;
            string sc=t.Status switch{EsportManager.Models.TournamentStatus.Ongoing=>"chip-red",EsportManager.Models.TournamentStatus.Registration=>"chip-green",EsportManager.Models.TournamentStatus.Upcoming=>"chip-cyan",_=>"chip-gray"};
            <tr>
              <td style="max-width:220px;">
                <div style="font-weight:700;font-size:13px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:var(--text-white);">@t.Name</div>
                <div style="font-size:11px;color:var(--text-dim);">@t.Region · @t.ViewCount views</div>
              </td>
              <td><span class="chip @(isLQ?"chip-lq":"chip-ff")" style="font-size:10px;">@(isLQ?"⚔ LQ":"🔥 FF")</span></td>
              <td style="font-size:12px;color:var(--text-dim);">@t.Format<br/>@t.MatchFormat</td>
              <td>
                <div style="font-family:'Rajdhani',sans-serif;font-weight:700;color:var(--text-white);">@t.Registrations.Count / @t.MaxTeams</div>
                <div class="elo-progress mt-1" style="width:60px;"><div class="@(isLQ?"elo-fill-lq":"elo-fill-ff")" style="width:@(t.MaxTeams>0?t.Registrations.Count*100/t.MaxTeams:0)%;"></div></div>
              </td>
              <td style="font-family:'Rajdhani',sans-serif;font-weight:700;color:@(isLQ?"var(--lq-gold)":"var(--ff-orange)");">@t.PrizePool</td>
              <td><span class="chip @sc">@t.Status</span></td>
              <td style="font-size:11px;color:var(--text-dim);">@t.TournamentStart.ToString("dd/MM") →<br/>@t.TournamentEnd.ToString("dd/MM/yy")</td>
              <td>
                <a href="/Tournament/Detail/@t.Id" class="btn btn-outline btn-sm" style="font-size:11px;">Detail</a>
                <a href="/Tournament/Bracket/@t.Id" class="btn btn-cyan btn-sm" style="font-size:11px;margin-top:4px;display:block;">Bracket</a>
              </td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  </main>
</div>
<script src="~/js/site.js"></script>
</body></html>
