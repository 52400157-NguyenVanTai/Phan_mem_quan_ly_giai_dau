@* Admin/Users.cshtml *@
@model List<EsportManager.Models.User>
@{ViewData["Title"]="Admin – Users"; Layout=null;}
<!DOCTYPE html><html lang="vi"><head><meta charset="utf-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>Admin Users — EsportArena</title>
<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;600;700&family=Exo+2:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
<link rel="stylesheet" href="~/css/site.css"/></head>
<body style="margin:0;">
<div class="admin-layout">
  <aside class="admin-sidebar">
    <div class="sidebar-logo"><div class="logo-title">ESPORT<span>ARENA</span></div><div class="admin-badge">ADMIN PANEL</div></div>
    <div class="sidebar-section">
      <a href="/Admin" class="sidebar-link"><i class="fas fa-tachometer-alt"></i> Dashboard</a>
      <a href="/Admin/Tournaments" class="sidebar-link"><i class="fas fa-trophy"></i> Giải Đấu</a>
      <a href="/Admin/Registrations" class="sidebar-link"><i class="fas fa-clipboard-list"></i> Duyệt Đăng Ký</a>
      <a href="/Admin/Users" class="sidebar-link active"><i class="fas fa-users"></i> Người Dùng</a>
      <a href="/Match" class="sidebar-link"><i class="fas fa-gamepad"></i> Trận Đấu</a>
    </div>
    <div class="sidebar-section"><a href="/" class="sidebar-link"><i class="fas fa-home"></i> Trang Chủ</a><a href="/Account/Logout" class="sidebar-link" style="color:var(--danger);"><i class="fas fa-sign-out-alt"></i> Đăng Xuất</a></div>
  </aside>
  <main class="admin-main">
    <div class="admin-topbar">
      <div><div class="admin-page-title">👥 Quản Lý Người Dùng</div><div class="admin-page-subtitle">Tổng: <b style="color:var(--cyan)">@Model.Count</b> tài khoản</div></div>
    </div>
    @if(TempData["Success"]!=null){<div class="toast-bar mb-20"><i class="fas fa-check-circle"></i> @TempData["Success"]</div>}
    <div class="panel">
      <div class="panel-header"><span class="panel-title">DANH SÁCH NGƯỜI DÙNG</span></div>
      <table class="admin-table">
        <thead><tr><th>ID</th><th>Ingame Name</th><th>Email</th><th>LQ UID</th><th>FF UID</th><th>Rank LQ</th><th>Rank FF</th><th>Trạng Thái</th><th>Thao Tác</th></tr></thead>
        <tbody>
          @foreach(var u in Model)
          {
            <tr>
              <td style="color:var(--text-dim);font-size:12px;">#@u.Id</td>
              <td><div style="font-weight:700;color:var(--text-white);">@u.IngameName</div><div style="font-size:11px;color:var(--text-dim);">@@u.Username</div></td>
              <td style="font-size:12px;color:var(--text-dim);">@u.Email</td>
              <td style="font-size:12px;color:var(--lq-gold);">@(string.IsNullOrEmpty(u.GameUID_LQ)?"-":u.GameUID_LQ)</td>
              <td style="font-size:12px;color:var(--ff-orange);">@(string.IsNullOrEmpty(u.GameUID_FF)?"-":u.GameUID_FF)</td>
              <td><span class="chip chip-lq" style="font-size:10px;">@u.Rank_LQ</span></td>
              <td><span class="chip chip-ff" style="font-size:10px;">@u.Rank_FF</span></td>
              <td>
                @if(u.IsBanned){<span class="chip chip-red">BANNED</span>}
                else if(u.IsAdmin){<span class="chip chip-lq">ADMIN</span>}
                else if(u.IsVerified){<span class="chip chip-green">✓ VERIFIED</span>}
                else{<span class="chip chip-warn">UNVERIFIED</span>}
              </td>
              <td>
                <a href="/Account/Profile/@u.Id" class="btn btn-outline btn-sm">Profile</a>
                @if(!u.IsAdmin){
                  <form method="post" action="/Admin/BanUser" style="display:inline;margin-left:4px;">
                    <input type="hidden" name="id" value="@u.Id"/>
                    <button type="submit" class="btn btn-sm @(u.IsBanned?"btn-success":"btn-danger")" onclick="return confirm('@(u.IsBanned?"Unban":"Ban") user này?')">@(u.IsBanned?"Unban":"Ban")</button>
                  </form>
                }
              </td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  </main>
</div>
<script src="~/js/site.js"></script>
</body></html>
