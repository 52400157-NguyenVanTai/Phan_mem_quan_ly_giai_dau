@model List<EsportManager.Models.TournamentRegistration>
@{ViewData["Title"]="Admin – Đăng Ký"; Layout=null;}
<!DOCTYPE html><html lang="vi"><head><meta charset="utf-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>Admin Registrations — EsportArena</title>
<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;600;700&family=Exo+2:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
<link rel="stylesheet" href="~/css/site.css"/></head>
<body style="margin:0;">
<div class="admin-layout">
  <aside class="admin-sidebar">
    <div class="sidebar-logo"><div class="logo-title">ESPORT<span>ARENA</span></div><div class="admin-badge">ADMIN PANEL</div></div>
    <div class="sidebar-section">
      <a href="/Admin" class="sidebar-link"><i class="fas fa-tachometer-alt"></i> Dashboard</a>
      <a href="/Admin/Tournaments" class="sidebar-link"><i class="fas fa-trophy"></i> Giải Đấu</a>
      <a href="/Admin/Registrations" class="sidebar-link active"><i class="fas fa-clipboard-list"></i> Duyệt Đăng Ký <span class="badge">@Model.Count</span></a>
      <a href="/Admin/Users" class="sidebar-link"><i class="fas fa-users"></i> Người Dùng</a>
      <a href="/Match" class="sidebar-link"><i class="fas fa-gamepad"></i> Trận Đấu</a>
    </div>
    <div class="sidebar-section"><a href="/" class="sidebar-link"><i class="fas fa-home"></i> Trang Chủ</a><a href="/Account/Logout" class="sidebar-link" style="color:var(--danger);"><i class="fas fa-sign-out-alt"></i> Đăng Xuất</a></div>
  </aside>
  <main class="admin-main">
    <div class="admin-topbar">
      <div><div class="admin-page-title">📋 Duyệt Đăng Ký</div><div class="admin-page-subtitle"><b style="color:var(--warning)">@Model.Count</b> đơn đang chờ duyệt</div></div>
    </div>
    @if(TempData["Success"]!=null){<div class="toast-bar mb-20"><i class="fas fa-check-circle"></i> @TempData["Success"]</div>}
    @if(!Model.Any())
    {
      <div style="text-align:center;padding:80px;background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);">
        <div style="font-size:48px;margin-bottom:12px;">✅</div>
        <div style="font-family:'Rajdhani',sans-serif;font-size:20px;color:var(--success);">Không còn đơn nào chờ duyệt!</div>
      </div>
    }
    else
    {
      <div class="panel">
        <div class="panel-header"><span class="panel-title">DANH SÁCH ĐƠN ĐĂNG KÝ ĐANG CHỜ</span></div>
        <table class="admin-table">
          <thead><tr><th>#</th><th>Đội</th><th>Game</th><th>Giải Đấu</th><th>Ngày Đăng Ký</th><th>Thao Tác</th></tr></thead>
          <tbody>
            @foreach(var r in Model)
            {
              var t=EsportManager.Services.MockData.Tournaments.FirstOrDefault(x=>x.Id==r.TournamentId);
              bool isLQ=t?.Game==EsportManager.Models.GameType.LienQuan;
              <tr>
                <td style="color:var(--text-dim);font-size:12px;">#@r.Id</td>
                <td>
                  <div style="display:flex;align-items:center;gap:10px;">
                    <div style="font-size:22px;">@(isLQ?"⚔️":"🔥")</div>
                    <div><div style="font-weight:700;color:var(--text-white);">@(r.Team?.Name??"N/A")</div><div style="font-size:11px;color:var(--text-dim);">[@(r.Team?.Tag??"???")] · @(r.Team?.Captain?.IngameName??"")</div></div>
                  </div>
                </td>
                <td><span class="chip @(isLQ?"chip-lq":"chip-ff")">@(isLQ?"⚔ LQ":"🔥 FF")</span></td>
                <td><div style="font-weight:600;font-size:13px;max-width:220px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@(t?.Name??"N/A")</div><div style="font-size:11px;color:var(--text-dim);">@(t?.MatchFormat) · Max @(t?.MaxTeams) đội</div></td>
                <td style="font-size:12px;color:var(--text-dim);">@r.RegisteredAt.ToString("dd/MM/yyyy HH:mm")</td>
                <td>
                  <form method="post" action="/Admin/Approve" style="display:inline;">
                    <input type="hidden" name="id" value="@r.Id"/>
                    <button type="submit" class="btn btn-success btn-sm"><i class="fas fa-check"></i> Duyệt</button>
                  </form>
                  <form method="post" action="/Admin/Reject" style="display:inline;margin-left:6px;">
                    <input type="hidden" name="id" value="@r.Id"/>
                    <button type="submit" class="btn btn-danger btn-sm"><i class="fas fa-times"></i> Từ Chối</button>
                  </form>
                </td>
              </tr>
            }
          </tbody>
        </table>
      </div>
    }
  </main>
</div>
<script src="~/js/site.js"></script>
</body></html>
