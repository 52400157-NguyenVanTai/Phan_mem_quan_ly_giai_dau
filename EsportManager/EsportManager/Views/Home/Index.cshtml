@{
    ViewData["Title"] = "Trang Chủ";
    var featured = ViewBag.FeaturedTournaments as List<EsportManager.Models.Tournament>;
    var liveMatches = ViewBag.LiveMatches as List<EsportManager.Models.Match>;
    var upcoming = ViewBag.UpcomingMatches as List<EsportManager.Models.Match>;
    var topLQ = ViewBag.TopTeams_LQ as List<EsportManager.Models.Team>;
    var topFF = ViewBag.TopTeams_FF as List<EsportManager.Models.Team>;
    var recentResults = ViewBag.RecentResults as List<EsportManager.Models.Match>;
}

<!-- HERO -->
<section class="hero">
  <div class="hero-grid-bg"></div>
  <div class="hero-gradient"></div>
  <div class="hero-scan-line"></div>
  <div class="hero-content">
    <div class="hero-eyebrow">
      <div class="dot"></div>
      ESPORT ARENA VN — SEASON 2026
    </div>
    <h1 class="hero-title">
      QUẢN LÝ <span class="accent-lq">GIẢI ĐẤU</span><br>
      <span class="accent-ff">LIÊN QUÂN</span> &amp; <span class="accent-cyan">FREE FIRE</span>
    </h1>
    <p class="hero-desc">Nền tảng tổ chức và tham gia giải đấu esport chuyên nghiệp. Bracket tự động, hệ thống xếp hạng ELO, quản lý đội và trận đấu realtime.</p>
    <div class="hero-actions">
      <a href="/Tournament" class="btn btn-cyan"><i class="fas fa-trophy"></i> Xem Giải Đấu</a>
      <a href="/Tournament/Create" class="btn btn-outline"><i class="fas fa-plus"></i> Tổ Chức Giải</a>
      <a href="/Team/Create" class="btn btn-outline"><i class="fas fa-users"></i> Lập Đội</a>
    </div>
    <!-- STATS -->
    <div style="display:flex;gap:32px;margin-top:36px;flex-wrap:wrap;">
      @{
        var stats = new[] {
          new { Val = EsportManager.Services.MockData.Tournaments.Count, Lbl = "Giải Đấu" },
          new { Val = EsportManager.Services.MockData.Teams.Count, Lbl = "Đội Thi Đấu" },
          new { Val = EsportManager.Services.MockData.Users.Count, Lbl = "Game Thủ" },
          new { Val = EsportManager.Services.MockData.Matches.Count, Lbl = "Trận Đấu" }
        };
      }
      @foreach (var s in stats)
      {
        <div>
          <div style="font-family:'Rajdhani',sans-serif;font-size:28px;font-weight:700;color:var(--cyan);" data-count="@s.Val">@s.Val</div>
          <div style="font-size:11px;color:var(--text-dim);letter-spacing:1px;text-transform:uppercase;">@s.Lbl</div>
        </div>
      }
    </div>
  </div>
  <!-- HERO GAME ICONS RIGHT -->
  <div class="hero-right">
    <div style="display:flex;flex-direction:column;gap:24px;align-items:center;opacity:0.6;">
      <div style="font-size:100px;filter:drop-shadow(0 0 30px var(--lq-gold));animation:float1 4s ease-in-out infinite;">⚔️</div>
      <div style="font-size:80px;filter:drop-shadow(0 0 30px var(--ff-orange));animation:float2 4s ease-in-out infinite 2s;">🔥</div>
    </div>
  </div>
</section>

<!-- LIVE TICKER -->
@if (liveMatches != null && liveMatches.Any())
{
  <div style="background:rgba(255,23,68,0.1);border-bottom:1px solid rgba(255,23,68,0.3);padding:8px 24px;display:flex;align-items:center;gap:16px;overflow:hidden;">
    <div class="live-pip" style="display: inline-flex; align-items: center;">
    <div class="dot"></div>LIVE
    </div>
    @foreach (var m in liveMatches)
    {
      <span style="font-family:'Rajdhani',sans-serif;font-size:14px;font-weight:700;color:var(--text-white);white-space:nowrap;">
        [@(m.Team1?.Tag??"???")] @(m.Team1?.Name??"TBD")
        <span style="color:var(--live-red);margin:0 8px;">@m.Team1Score — @m.Team2Score</span>
        @(m.Team2?.Name??"TBD") [@(m.Team2?.Tag??"???")]
        <a href="/Match/Detail/@m.Id" style="color:var(--cyan);font-size:12px;margin-left:10px;">Xem →</a>
        <span style="color:var(--text-muted);margin:0 16px;">|</span>
      </span>
    }
  </div>
}

<div class="page-section">
  <div class="container">

    <!-- GAME SWITCHER -->
    <div style="display:flex;gap:12px;margin-bottom:28px;flex-wrap:wrap;">
      <a href="/Tournament?game=LienQuan" class="btn btn-lq"><i class="fas fa-sword"></i> Liên Quân Mobile</a>
      <a href="/Tournament?game=FreeFire" class="btn btn-ff"><i class="fas fa-fire"></i> Free Fire</a>
      <a href="/Tournament?status=Registration" class="btn btn-outline" style="margin-left:auto;"><i class="fas fa-clipboard-list"></i> Đang Mở Đăng Ký</a>
    </div>

    <!-- FEATURED TOURNAMENTS -->
    <div class="sec-header">
      <div class="sec-title-wrap">
        <span class="sec-icon">🏆</span>
        <h2 class="sec-title">Giải Đấu <span class="hl-cyan">Nổi Bật</span></h2>
      </div>
      <div class="sec-line"></div>
      <a href="/Tournament" class="sec-link">Xem tất cả →</a>
    </div>
    <div class="t-grid mb-30">
      @if (featured != null)
      {
        @foreach (var t in featured)
        {
          bool isLQ = t.Game == EsportManager.Models.GameType.LienQuan;
          string statusClass = t.Status switch {
            EsportManager.Models.TournamentStatus.Ongoing => "status-ongoing",
            EsportManager.Models.TournamentStatus.Registration => "status-registration",
            EsportManager.Models.TournamentStatus.Upcoming => "status-upcoming",
            EsportManager.Models.TournamentStatus.Completed => "status-completed",
            _ => "status-completed"
          };
          string statusText = t.Status switch {
            EsportManager.Models.TournamentStatus.Ongoing => "🔴 ĐANG DIỄN RA",
            EsportManager.Models.TournamentStatus.Registration => "🟢 ĐĂNG KÝ MỞ",
            EsportManager.Models.TournamentStatus.Upcoming => "🔵 SẮP DIỄN RA",
            EsportManager.Models.TournamentStatus.Completed => "⬜ ĐÃ KẾT THÚC",
            _ => t.Status.ToString()
          };
          <a href="/Tournament/Detail/@t.Id" class="t-card @(isLQ ? "lq-card" : "ff-card")">
            <div class="t-card-banner">
              @if (isLQ) { <div class="lq-banner-bg"></div><div class="t-card-banner-glow lq-glow-circle" style="top:50%;left:50%;transform:translate(-50%,-50%)"></div> }
              else { <div class="ff-banner-bg"></div><div class="t-card-banner-glow ff-glow-circle" style="top:50%;left:50%;transform:translate(-50%,-50%)"></div> }
              <div class="t-card-banner-icon @(isLQ ? "lq-icon-color" : "ff-icon-color")">@(isLQ ? "⚔️" : "🔥")</div>
              <div class="t-status-pill @statusClass">@statusText</div>
              @if (t.IsFeatured) { <div class="t-card-feat">⭐ NỔI BẬT</div> }
            </div>
            <div class="t-card-body">
              <div>
                <span class="t-card-game-tag @(isLQ ? "tag-lq" : "tag-ff")">@(isLQ ? "⚔ LIÊN QUÂN" : "🔥 FREE FIRE")</span>
                <span class="t-card-game-tag tag-format">@t.MatchFormat</span>
              </div>
              <div class="t-card-name">@t.Name</div>
              <div class="t-card-meta">
                <div class="t-card-meta-item"><i class="fas fa-sitemap"></i>@t.Format</div>
                <div class="t-card-meta-item"><i class="fas fa-users"></i>Max @t.MaxTeams đội</div>
                <div class="t-card-meta-item"><i class="far fa-calendar"></i>@t.TournamentStart.ToString("dd/MM/yyyy")</div>
              </div>
              @if (!string.IsNullOrEmpty(t.PrizePool))
              {
                <div class="t-card-prize @(isLQ ? "prize-lq" : "prize-ff")">
                  🏆 Prize Pool: @t.PrizePool
                </div>
              }
              <div class="t-card-footer">
                <div class="t-card-slots">
                  <div>@t.Registrations.Count / @t.MaxTeams đội</div>
                  <div class="slot-bar mt-1"><div class="@(isLQ ? "slot-fill-lq" : "slot-fill-ff")" style="width:@(t.MaxTeams > 0 ? (t.Registrations.Count * 100 / t.MaxTeams) : 0)%"></div></div>
                </div>
                <span class="btn btn-sm @(isLQ ? "btn-lq" : "btn-ff")">Chi Tiết</span>
              </div>
            </div>
          </a>
        }
      }
    </div>

    <!-- TWO COLUMN: MATCHES + RANKINGS -->
    <div style="display:grid;grid-template-columns:1fr 340px;gap:24px;">
      <div>
        <!-- UPCOMING MATCHES -->
        <div class="sec-header">
          <div class="sec-title-wrap">
            <span class="sec-icon">📅</span>
            <h2 class="sec-title">Trận Đấu <span class="hl-cyan">Sắp Diễn Ra</span></h2>
          </div>
          <div class="sec-line"></div>
          <a href="/Match" class="sec-link">Xem tất cả →</a>
        </div>
        @if (upcoming != null)
        {
          @foreach (var m in upcoming)
          {
            bool isLQ = m.Tournament?.Game == EsportManager.Models.GameType.LienQuan;
            <div class="match-card">
              <div style="text-align:center;min-width:55px;flex-shrink:0;">
                <div style="font-size:20px;">@(isLQ ? "⚔️" : "🔥")</div>
                <div style="font-size:11px;color:var(--text-dim);margin-top:4px;font-family:'Rajdhani',sans-serif;font-weight:700;">@m.ScheduledAt.ToString("HH:mm")</div>
                <div style="font-size:10px;color:var(--text-muted);">@m.ScheduledAt.ToString("dd/MM")</div>
              </div>
              <div class="match-teams">
                <div class="match-team">
                  <div class="match-team-tag">[@(m.Team1?.Tag ?? "???")]</div>
                  <div class="match-team-name">@(m.Team1?.Name ?? "TBD")</div>
                </div>
                <div class="match-center">
                  <div class="match-vs">VS</div>
                  <div class="match-round">@m.RoundName</div>
                </div>
                <div class="match-team">
                  <div class="match-team-tag">[@(m.Team2?.Tag ?? "???")]</div>
                  <div class="match-team-name">@(m.Team2?.Name ?? "TBD")</div>
                </div>
              </div>
              @if (!string.IsNullOrEmpty(m.RoomId))
              {
                <div style="text-align:right;flex-shrink:0;">
                  <div style="font-size:11px;color:var(--text-dim);">Room ID</div>
                  <div style="font-family:'Rajdhani',sans-serif;color:var(--cyan);font-weight:700;font-size:13px;">@m.RoomId</div>
                </div>
              }
              <a href="/Match/Detail/@m.Id" class="btn btn-sm btn-outline">Detail</a>
            </div>
          }
        }

        <!-- RECENT RESULTS -->
        <div class="sec-header mt-20">
          <div class="sec-title-wrap"><span class="sec-icon">✅</span><h2 class="sec-title">Kết Quả Gần Đây</h2></div>
          <div class="sec-line"></div>
        </div>
        @if (recentResults != null)
        {
          @foreach (var m in recentResults)
          {
            <div class="match-card">
              <div class="match-teams">
                <div class="match-team">
                  <div class="match-team-tag">[@(m.Team1?.Tag ?? "???")]</div>
                  <div class="match-team-name @(m.WinnerId == m.Team1Id ? "winner" : "")">@(m.Team1?.Name ?? "TBD")</div>
                  @if (m.WinnerId == m.Team1Id) { <div style="font-size:11px;color:var(--lq-gold);">🏆 WINNER</div> }
                </div>
                <div class="match-center">
                  <div class="match-score-display">@m.Team1Score — @m.Team2Score</div>
                  <div class="match-round">@m.RoundName</div>
                </div>
                <div class="match-team">
                  <div class="match-team-tag">[@(m.Team2?.Tag ?? "???")]</div>
                  <div class="match-team-name @(m.WinnerId == m.Team2Id ? "winner" : "")">@(m.Team2?.Name ?? "TBD")</div>
                  @if (m.WinnerId == m.Team2Id) { <div style="font-size:11px;color:var(--lq-gold);">🏆 WINNER</div> }
                </div>
              </div>
              <a href="/Match/Detail/@m.Id" class="btn btn-sm btn-outline">Chi tiết</a>
            </div>
          }
        }
      </div>

      <!-- SIDEBAR -->
      <div>
        <!-- TOP LQ TEAMS -->
        <div class="widget mb-20">
          <div class="widget-head" style="color:var(--lq-gold);">⚔ TOP Liên Quân</div>
          <div class="widget-body">
            @if (topLQ != null)
            {
              int r = 1;
              @foreach (var t in topLQ)
              {
                <div class="rank-item">
                  <div class="rank-num @(r==1?"rank-1":r==2?"rank-2":r==3?"rank-3":"")">@r</div>
                  <div class="rn"><div style="font-weight:700;font-size:14px;">@t.Name</div><div style="font-size:11px;color:var(--text-dim);">@t.Wins W – @t.Losses L</div></div>
                  <div class="rp" style="color:var(--lq-gold);">@t.Points</div>
                </div>
                r++;
              }
            }
            <a href="/Ranking?game=LienQuan" class="btn btn-sm btn-lq btn-full mt-12">BXH Đầy Đủ</a>
          </div>
        </div>

        <!-- TOP FF TEAMS -->
        <div class="widget mb-20">
          <div class="widget-head" style="color:var(--ff-orange);">🔥 TOP Free Fire</div>
          <div class="widget-body">
            @if (topFF != null)
            {
              int r = 1;
              @foreach (var t in topFF)
              {
                <div class="rank-item">
                  <div class="rank-num @(r==1?"rank-1":r==2?"rank-2":r==3?"rank-3":"")">@r</div>
                  <div class="rn"><div style="font-weight:700;font-size:14px;">@t.Name</div><div style="font-size:11px;color:var(--text-dim);">@t.Wins W – @t.Losses L</div></div>
                  <div class="rp" style="color:var(--ff-orange);">@t.Points</div>
                </div>
                r++;
              }
            }
            <a href="/Ranking?game=FreeFire" class="btn btn-sm btn-ff btn-full mt-12">BXH Đầy Đủ</a>
          </div>
        </div>

        <!-- CTA -->
        <div style="background:linear-gradient(135deg,rgba(0,229,255,0.08),rgba(255,193,7,0.05));border:1px solid var(--border);border-radius:var(--radius);padding:20px;text-align:center;">
          <div style="font-size:36px;margin-bottom:12px;">🎮</div>
          <div style="font-family:'Rajdhani',sans-serif;font-size:18px;font-weight:700;margin-bottom:8px;">Muốn tổ chức giải?</div>
          <p style="font-size:13px;color:var(--text-dim);margin-bottom:16px;">Tạo giải đấu Liên Quân hoặc Free Fire trong vài phút</p>
          <a href="/Tournament/Create" class="btn btn-cyan btn-full"><i class="fas fa-plus"></i> Tạo Giải Ngay</a>
        </div>
      </div>
    </div>

  </div>
</div>
