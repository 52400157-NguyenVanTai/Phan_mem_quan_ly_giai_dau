@* Tournament/Bracket.cshtml *@
@model EsportManager.Models.Tournament
@{ViewData["Title"]="Bracket – "+Model.Name; bool isLQ=Model.Game==EsportManager.Models.GameType.LienQuan; var matches=ViewBag.Matches as List<EsportManager.Models.Match>; int max=ViewBag.MaxRound??1;}
<div class="page-banner"><div class="page-banner-inner"><div class="breadcrumb"><a href="/Tournament/Detail/@Model.Id">@Model.Name</a><span>/</span>Cây Đấu</div><h1><i class="fas fa-sitemap" style="color:var(--cyan);margin-right:10px;"></i>CÂY ĐẤU — @Model.Name</h1></div></div>
<div class="page-section">
  <div class="container">
    <div class="panel">
      <div class="panel-header">
        <span class="panel-title">@(isLQ?"⚔ LIÊN QUÂN":"🔥 FREE FIRE") BRACKET — @Model.Format</span>
        <a href="/Tournament/Detail/@Model.Id" class="btn btn-outline btn-sm">← Quay Lại</a>
      </div>
      <div class="panel-body">
        <div class="bracket-wrap">
          <div class="bracket">
            @for (int rd = 1; rd <= max; rd++)
            {
              var rdMatches = matches?.Where(m => m.Round == rd).ToList();
              string rdName = rd == max ? "GRAND FINAL" : rd == max-1 ? "SEMI FINAL" : rd == max-2 ? "QUARTER FINAL" : $"ROUND {rd}";
              <div class="bracket-round" style="padding-top:@((rd-1)*24)px;">
                <div class="round-label">@rdName</div>
                @if (rdMatches != null && rdMatches.Any())
                {
                  @foreach (var m in rdMatches)
                  {
                    <div class="bracket-match-card" style="margin-bottom:@(rd*22+10)px;">
                      <div class="b-team @(m.WinnerId==m.Team1Id?"b-win":m.Status==EsportManager.Models.MatchStatus.Completed?"b-loss":"")">
                        <span>@(m.Team1?.Tag??"")<b style="margin-left:5px;">@(m.Team1?.Name??"TBD")</b></span>
                        <div class="b-score @(m.WinnerId==m.Team1Id?"win-score":"")">@m.Team1Score</div>
                      </div>
                      <div class="b-team @(m.WinnerId==m.Team2Id?"b-win":m.Status==EsportManager.Models.MatchStatus.Completed?"b-loss":"")">
                        <span>@(m.Team2?.Tag??"")<b style="margin-left:5px;">@(m.Team2?.Name??"TBD")</b></span>
                        <div class="b-score @(m.WinnerId==m.Team2Id?"win-score":"")">@m.Team2Score</div>
                      </div>
                      <div class="b-match-footer">@m.ScheduledAt.ToString("dd/MM HH:mm") @(m.Status==EsportManager.Models.MatchStatus.Live?"🔴 LIVE":"")</div>
                    </div>
                  }
                }
                else
                {
                  <div class="bracket-match-card" style="margin-bottom:32px;">
                    <div class="b-team"><span style="color:var(--text-muted);">TBD</span><div class="b-score">-</div></div>
                    <div class="b-team"><span style="color:var(--text-muted);">TBD</span><div class="b-score">-</div></div>
                    <div class="b-match-footer">Chưa xếp</div>
                  </div>
                }
              </div>
            }
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
