@model EsportManager.Models.Tournament
@{
  ViewData["Title"] = Model.Name;
  bool isLQ = Model.Game == EsportManager.Models.GameType.LienQuan;
  var teams = ViewBag.ApprovedTeams as List<EsportManager.Models.Team>;
  var matches = ViewBag.Matches as List<EsportManager.Models.Match>;
  string accentColor = isLQ ? "var(--lq-gold)" : "var(--ff-orange)";
}
<div class="page-banner" style="border-bottom-color:@accentColor;">
  <div class="page-banner-inner">
    <div class="breadcrumb"><a href="/">Home</a><span>/</span><a href="/Tournament">Giải Đấu</a><span>/</span>@Model.Name</div>
    <div style="display:flex;align-items:center;gap:16px;margin-top:10px;">
      <div style="font-size:48px;filter:drop-shadow(0 0 16px @accentColor);">@(isLQ?"⚔️":"🔥")</div>
      <div>
        <div>
          <span class="chip @(isLQ?"chip-lq":"chip-ff")">@(isLQ?"LIÊN QUÂN MOBILE":"FREE FIRE")</span>
          <span class="chip chip-cyan" style="margin-left:6px;">@Model.MatchFormat</span>
          <span class="chip chip-cyan" style="margin-left:6px;">@Model.Format</span>
        </div>
        <h1 style="margin-top:8px;">@Model.Name</h1>
        @{ var sc2 = Model.Status switch { EsportManager.Models.TournamentStatus.Ongoing=>"chip-red",EsportManager.Models.TournamentStatus.Registration=>"chip-green",EsportManager.Models.TournamentStatus.Upcoming=>"chip-cyan",_=>"chip-gray" };
           var st2 = Model.Status switch { EsportManager.Models.TournamentStatus.Ongoing=>"🔴 ĐANG DIỄN RA",EsportManager.Models.TournamentStatus.Registration=>"🟢 ĐĂNG KÝ ĐÃ MỞ",EsportManager.Models.TournamentStatus.Upcoming=>"🔵 SẮP DIỄN RA",_=>"⬜ ĐÃ KẾT THÚC" }; }
        <span class="chip @sc2" style="margin-top:8px;display:inline-block;">@st2</span>
        <span style="font-size:13px;color:var(--text-dim);margin-left:12px;"><i class="fas fa-eye me-1"></i>@Model.ViewCount lượt xem</span>
      </div>
    </div>
  </div>
</div>

<div class="page-section">
  <div class="container">
    <div class="page-layout">
      <div>
        <!-- PRIZE POOL BANNER -->
        @if (!string.IsNullOrEmpty(Model.PrizePool))
        {
          <div style="background:linear-gradient(135deg,@(isLQ?"rgba(255,193,7,0.08)":"rgba(255,87,34,0.08)"),transparent);border:1px solid @(isLQ?"rgba(255,193,7,0.3)":"rgba(255,87,34,0.3)");border-radius:var(--radius);padding:20px;margin-bottom:20px;display:flex;align-items:center;gap:20px;">
            <div style="font-size:48px;">🏆</div>
            <div>
              <div style="font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(--text-dim);font-weight:700;">PRIZE POOL</div>
              <div style="font-family:'Rajdhani',sans-serif;font-size:32px;font-weight:700;color:@accentColor;">@Model.PrizePool</div>
            </div>
            <div style="margin-left:auto;">
              <div class="prize-podium" style="min-width:260px;">
                @if (!string.IsNullOrEmpty(Model.Prize1st)){<div class="prize-box first"><div class="prize-medal">🥇</div><div class="prize-place">1st</div><div class="prize-amount @(isLQ?"prize-lq-color":"prize-ff-color")">@Model.Prize1st</div></div>}
                @if (!string.IsNullOrEmpty(Model.Prize2nd)){<div class="prize-box second"><div class="prize-medal">🥈</div><div class="prize-place">2nd</div><div class="prize-amount" style="color:#9e9e9e;">@Model.Prize2nd</div></div>}
                @if (!string.IsNullOrEmpty(Model.Prize3rd)){<div class="prize-box third"><div class="prize-medal">🥉</div><div class="prize-place">3rd</div><div class="prize-amount" style="color:#cd7f32;">@Model.Prize3rd</div></div>}
              </div>
            </div>
          </div>
        }

        <!-- TABS -->
        <div class="tabs-bar">
          <button class="tab-btn active" onclick="switchTab('t-info',this)">📋 Thông Tin</button>
          <button class="tab-btn" onclick="switchTab('t-teams',this)">🛡 Đội Tham Gia (@(teams?.Count??0))</button>
          <button class="tab-btn" onclick="switchTab('t-matches',this)">⚡ Lịch Thi Đấu</button>
          <button class="tab-btn" onclick="switchTab('t-bracket',this)">🏆 Cây Đấu</button>
          <button class="tab-btn" onclick="switchTab('t-rules',this)">📜 Thể Lệ</button>
        </div>

        <!-- INFO TAB -->
        <div id="t-info" class="tab-pane active">
          <div class="panel">
            <div class="panel-header"><span class="panel-title">Thông Tin Giải Đấu</span></div>
            <div class="panel-body">
              @if (!string.IsNullOrEmpty(Model.Description)){<p style="color:var(--text-dim);margin-bottom:20px;line-height:1.8;">@Model.Description</p>}
              <div class="info-row"><i class="fas fa-gamepad"></i><span class="info-lbl">Game:</span><span class="info-val"><span class="chip @(isLQ?"chip-lq":"chip-ff")">@(isLQ?"⚔ Liên Quân Mobile":"🔥 Free Fire")</span></span></div>
              <div class="info-row"><i class="fas fa-sitemap"></i><span class="info-lbl">Thể thức:</span><span class="info-val">@Model.Format — @Model.MatchFormat</span></div>
              <div class="info-row"><i class="fas fa-users"></i><span class="info-lbl">Số đội max:</span><span class="info-val">@Model.MaxTeams đội | @Model.MinPlayers–@Model.MaxPlayers người/đội</span></div>
              <div class="info-row"><i class="fas fa-globe"></i><span class="info-lbl">Region:</span><span class="info-val">@Model.Region</span></div>
              <div class="info-row"><i class="fas fa-clipboard-list"></i><span class="info-lbl">Đăng ký:</span><span class="info-val">@Model.RegistrationStart.ToString("dd/MM/yyyy") → @Model.RegistrationEnd.ToString("dd/MM/yyyy")</span></div>
              <div class="info-row"><i class="fas fa-sign-in-alt"></i><span class="info-lbl">Check-in:</span><span class="info-val">@Model.CheckInStart.ToString("dd/MM/yyyy HH:mm")</span></div>
              <div class="info-row"><i class="fas fa-flag"></i><span class="info-lbl">Thi đấu:</span><span class="info-val">@Model.TournamentStart.ToString("dd/MM/yyyy") → @Model.TournamentEnd.ToString("dd/MM/yyyy")</span></div>
              <div class="info-row"><i class="fas fa-user-shield"></i><span class="info-lbl">Organizer:</span><span class="info-val">@(Model.Organizer?.IngameName ?? Model.Organizer?.Username ?? "EsportArena")</span></div>
            </div>
          </div>
        </div>

        <!-- TEAMS TAB -->
        <div id="t-teams" class="tab-pane">
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
            @if (teams != null && teams.Any())
            {
              @foreach (var t in teams.Where(x => x != null))
              {
                <a href="/Team/Detail/@t!.Id" style="display:flex;align-items:center;gap:14px;padding:14px;background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);color:var(--text-white);transition:all 0.2s;">
                  <div style="font-size:32px;">🛡️</div>
                  <div>
                    <div style="font-family:'Rajdhani',sans-serif;font-weight:700;font-size:16px;">@t.Name</div>
                    <div class="chip @(t.PrimaryGame==EsportManager.Models.GameType.LienQuan?"chip-lq":"chip-ff")" style="font-size:10px;padding:2px 7px;margin-top:4px;">[@t.Tag]</div>
                  </div>
                  <div style="margin-left:auto;text-align:right;">
                    <div style="font-family:'Rajdhani',sans-serif;color:var(--cyan);font-size:15px;font-weight:700;">@t.Points</div>
                    <div style="font-size:11px;color:var(--text-dim);">@t.Wins W – @t.Losses L</div>
                  </div>
                </a>
              }
            }
            else{<div style="grid-column:span 2;text-align:center;padding:40px;color:var(--text-dim);">Chưa có đội được duyệt</div>}
          </div>
        </div>

        <!-- MATCHES TAB -->
        <div id="t-matches" class="tab-pane">
          @if (matches != null && matches.Any())
          {
            @foreach (var m in matches.OrderBy(x => x.Round))
            {
              <div class="match-card @(m.Status==EsportManager.Models.MatchStatus.Live?"is-live":"")">
                <div style="min-width:90px;text-align:center;flex-shrink:0;">
                  <div style="font-size:11px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:@accentColor;">@m.RoundName</div>
                  @if(m.Status==EsportManager.Models.MatchStatus.Live){<span class="live-pip mt-1"><div class="dot"></div>LIVE</span>}
                  else{<div style="font-size:12px;color:var(--text-dim);margin-top:4px;">@m.ScheduledAt.ToString("dd/MM HH:mm")</div>}
                </div>
                <div class="match-teams">
                  <div class="match-team"><div class="match-team-tag">[@(m.Team1?.Tag??"???")]</div><div class="match-team-name @(m.WinnerId==m.Team1Id?"winner":"")">@(m.Team1?.Name??"TBD")</div></div>
                  <div class="match-center">
                    @if(m.Status==EsportManager.Models.MatchStatus.Completed){<div class="match-score-display">@m.Team1Score — @m.Team2Score</div>}
                    else{<div class="match-vs">VS</div>}
                  </div>
                  <div class="match-team"><div class="match-team-tag">[@(m.Team2?.Tag??"???")]</div><div class="match-team-name @(m.WinnerId==m.Team2Id?"winner":"")">@(m.Team2?.Name??"TBD")</div></div>
                </div>
                <a href="/Match/Detail/@m.Id" class="btn btn-sm btn-outline">Detail</a>
              </div>
            }
          }
          else{<div style="text-align:center;padding:40px;color:var(--text-dim);">Lịch thi đấu chưa được tạo</div>}
        </div>

        <!-- BRACKET TAB -->
        <div id="t-bracket" class="tab-pane">
          <div class="panel">
            <div class="panel-header"><span class="panel-title">🏆 Cây Đấu Visual</span></div>
            <div class="panel-body">
              <a href="/Tournament/Bracket/@Model.Id" class="btn btn-cyan" style="margin-bottom:16px;">
                <i class="fas fa-sitemap"></i> Xem Cây Đấu Toàn Màn Hình
              </a>
              <p style="color:var(--text-dim);font-size:13px;">Click để xem bracket đầy đủ với giao diện trực quan</p>
            </div>
          </div>
        </div>

        <!-- RULES TAB -->
        <div id="t-rules" class="tab-pane">
          <div class="panel">
            <div class="panel-header"><span class="panel-title">📜 Thể Lệ Thi Đấu</span></div>
            <div class="panel-body">
              @if (!string.IsNullOrEmpty(Model.Rules))
              {
                <div style="color:var(--text-dim);line-height:2;font-size:14px;white-space:pre-line;">@Model.Rules</div>
              }
              else
              {
                <p style="color:var(--text-dim);">Thể lệ thi đấu sẽ được cập nhật sớm.</p>
              }
            </div>
          </div>
        </div>
      </div>

      <!-- SIDEBAR -->
      <div>
        @if (Model.Status == EsportManager.Models.TournamentStatus.Registration)
        {
          <div class="panel mb-20" style="border-color:@(isLQ?"rgba(255,193,7,0.4)":"rgba(255,87,34,0.4)");">
            <div class="panel-header" style="background:@(isLQ?"rgba(255,193,7,0.1)":"rgba(255,87,34,0.1)");border-bottom-color:@(isLQ?"rgba(255,193,7,0.3)":"rgba(255,87,34,0.3)");">
              <span class="panel-title" style="color:@accentColor;">🎮 ĐĂNG KÝ THAM GIA</span>
            </div>
            <div class="panel-body">
              <div style="background:var(--bg-surface);border-radius:var(--radius-sm);padding:12px;margin-bottom:14px;font-size:13px;color:var(--text-dim);">
                <i class="fas fa-clock" style="color:@accentColor;margin-right:8px;"></i>
                Hạn đăng ký: <b style="color:var(--text-white)">@Model.RegistrationEnd.ToString("dd/MM/yyyy")</b>
              </div>
              <div style="font-size:13px;color:var(--text-dim);margin-bottom:14px;">
                <div style="display:flex;justify-content:space-between;margin-bottom:6px;"><span>Slot đã đăng ký</span><b style="color:var(--text-white)">@Model.Registrations.Count / @Model.MaxTeams</b></div>
                <div class="slot-bar"><div class="@(isLQ?"slot-fill-lq":"slot-fill-ff")" style="width:@(Model.MaxTeams>0?Model.Registrations.Count*100/Model.MaxTeams:0)%"></div></div>
              </div>
              <form method="post" action="/Tournament/Register">
                <input type="hidden" name="tournamentId" value="@Model.Id" />
                <input type="hidden" name="teamId" value="1" />
                <button type="submit" class="btn @(isLQ?"btn-lq":"btn-ff") btn-full"><i class="fas fa-gamepad"></i> ĐĂNG KÝ NGAY</button>
              </form>
            </div>
          </div>
        }

        <div class="widget mb-20">
          <div class="widget-head">📊 Thống Kê</div>
          <div class="widget-body">
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
              @{var stats2=new[]{(Model.Registrations.Count.ToString(),"Đội Đăng Ký","var(--cyan)"),(Model.MaxTeams.ToString(),"Tổng Slot",accentColor),(matches?.Count.ToString()??"0","Trận Đấu","var(--success)"),(Model.MatchFormat.ToString(),"Format","var(--text-white)")};}
              @foreach(var s in stats2){<div style="background:var(--bg-surface);border:1px solid var(--border);border-radius:var(--radius-sm);padding:12px;text-align:center;"><div style="font-family:'Rajdhani',sans-serif;font-size:20px;font-weight:700;color:@s.Item3;">@s.Item1</div><div style="font-size:10px;color:var(--text-dim);text-transform:uppercase;letter-spacing:1px;margin-top:2px;">@s.Item2</div></div>}
            </div>
          </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.PrizePool))
        {
          <div class="widget mb-20">
            <div class="widget-head" style="color:@accentColor;">🏆 Giải Thưởng</div>
            <div class="widget-body">
              <div class="prize-podium">
                @if(!string.IsNullOrEmpty(Model.Prize1st)){<div class="prize-box first"><div class="prize-medal">🥇</div><div class="prize-place">1st</div><div class="prize-amount @(isLQ?"prize-lq-color":"prize-ff-color")">@Model.Prize1st</div></div>}
                @if(!string.IsNullOrEmpty(Model.Prize2nd)){<div class="prize-box second"><div class="prize-medal">🥈</div><div class="prize-place">2nd</div><div class="prize-amount" style="color:#9e9e9e;">@Model.Prize2nd</div></div>}
                @if(!string.IsNullOrEmpty(Model.Prize3rd)){<div class="prize-box third"><div class="prize-medal">🥉</div><div class="prize-place">3rd</div><div class="prize-amount" style="color:#cd7f32;">@Model.Prize3rd</div></div>}
              </div>
            </div>
          </div>
        }

        <div class="widget">
          <div class="widget-head">⏱ Countdown</div>
          <div class="widget-body" style="text-align:center;">
            @if (Model.Status == EsportManager.Models.TournamentStatus.Registration || Model.Status == EsportManager.Models.TournamentStatus.Upcoming)
            {
              <div style="font-size:12px;color:var(--text-dim);margin-bottom:6px;">Giải đấu bắt đầu trong</div>
              <div style="font-family:'Rajdhani',sans-serif;font-size:22px;font-weight:700;color:@accentColor;" data-countdown="@Model.TournamentStart.ToString("yyyy-MM-ddTHH:mm:ss")">Đang tính...</div>
            }
            else if (Model.Status == EsportManager.Models.TournamentStatus.Ongoing)
            {
              <div style="font-size:13px;color:var(--text-dim);margin-bottom:6px;">Giải đấu kết thúc vào</div>
              <div style="font-family:'Rajdhani',sans-serif;font-size:16px;font-weight:700;color:@accentColor;">@Model.TournamentEnd.ToString("dd/MM/yyyy")</div>
            }
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
