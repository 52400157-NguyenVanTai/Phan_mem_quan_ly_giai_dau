@{ViewData["Title"]="Tạo Giải Đấu";}
<div class="page-banner"><div class="page-banner-inner"><h1>🏆 TẠO GIẢI ĐẤU MỚI</h1><p>Tổ chức giải Liên Quân Mobile hoặc Free Fire chuyên nghiệp</p></div></div>
<div class="page-section">
  <div class="container">
    <div class="form-card" style="max-width:720px;">
      <div class="form-card-title">⚔ / 🔥 THIẾT LẬP GIẢI ĐẤU</div>
      <form method="post">
        <div class="form-group"><label class="form-label">Tên Giải Đấu *</label><input class="form-input" name="Name" placeholder="VD: FAG Liên Quân Open 2026" required /></div>
        <div class="form-group"><label class="form-label">Mô Tả</label><textarea class="form-input" name="Description" rows="3" placeholder="Mô tả về giải đấu..."></textarea></div>
        <div class="grid-2-form">
          <div class="form-group"><label class="form-label">Game *</label>
            <select class="form-input" name="Game">
              <option value="0">⚔ Liên Quân Mobile</option>
              <option value="1">🔥 Free Fire</option>
            </select>
          </div>
          <div class="form-group"><label class="form-label">Thể Thức *</label>
            <select class="form-input" name="Format">
              <option value="0">Single Elimination (Loại Trực Tiếp)</option>
              <option value="1">Double Elimination</option>
              <option value="2">Round Robin (Vòng Bảng)</option>
              <option value="3">Swiss System</option>
            </select>
          </div>
          <div class="form-group"><label class="form-label">Format Trận *</label>
            <select class="form-input" name="MatchFormat">
              <option value="0">BO1</option>
              <option value="1">BO3</option>
              <option value="2">BO5</option>
            </select>
          </div>
          <div class="form-group"><label class="form-label">Số Đội Tối Đa *</label>
            <select class="form-input" name="MaxTeams">
              <option>4</option><option>8</option><option selected>16</option><option>32</option><option>64</option>
            </select>
          </div>
          <div class="form-group"><label class="form-label">Đăng Ký Từ</label><input class="form-input" type="date" name="RegistrationStart" /></div>
          <div class="form-group"><label class="form-label">Đăng Ký Đến</label><input class="form-input" type="date" name="RegistrationEnd" /></div>
          <div class="form-group"><label class="form-label">Check-in</label><input class="form-input" type="datetime-local" name="CheckInStart" /></div>
          <div class="form-group"><label class="form-label">Bắt Đầu Thi Đấu</label><input class="form-input" type="date" name="TournamentStart" /></div>
          <div class="form-group"><label class="form-label">Kết Thúc</label><input class="form-input" type="date" name="TournamentEnd" /></div>
          <div class="form-group"><label class="form-label">Prize Pool</label><input class="form-input" name="PrizePool" placeholder="VD: 30,000,000 VNĐ" /></div>
          <div class="form-group"><label class="form-label">Giải 1st</label><input class="form-input" name="Prize1st" placeholder="15,000,000 VNĐ" /></div>
          <div class="form-group"><label class="form-label">Giải 2nd</label><input class="form-input" name="Prize2nd" placeholder="9,000,000 VNĐ" /></div>
        </div>
        <div class="form-group"><label class="form-label">Thể Lệ Thi Đấu</label><textarea class="form-input" name="Rules" rows="5" placeholder="- Mỗi đội 5-7 người&#10;- Check-in bắt buộc 30 phút trước&#10;- Nghiêm cấm cheat/hack&#10;..."></textarea></div>
        <button type="submit" class="btn btn-cyan btn-full"><i class="fas fa-trophy"></i> TẠO GIẢI ĐẤU</button>
      </form>
    </div>
  </div>
</div>
