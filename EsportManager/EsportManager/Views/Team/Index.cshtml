@* Team/Index.cshtml *@
@model List<EsportManager.Models.Team>
@{ViewData["Title"]="Đội Thi Đấu";}
<div class="page-banner"><div class="page-banner-inner"><div class="breadcrumb"><a href="/">Home</a><span>/</span>Đội</div><h1>🛡 ĐỘI THI ĐẤU ESPORT</h1><p>Các đội Liên Quân Mobile và Free Fire hàng đầu Việt Nam</p></div></div>
<div class="filter-strip">
  <div class="filter-inner">
    <a href="/Team" class="filter-btn @(ViewBag.Game==null?"active":"")">Tất Cả</a>
    <a href="/Team?game=LienQuan" class="filter-btn @(ViewBag.Game=="LienQuan"?"lq-active":"")">⚔ Liên Quân</a>
    <a href="/Team?game=FreeFire" class="filter-btn @(ViewBag.Game=="FreeFire"?"ff-active":"")">🔥 Free Fire</a>
    <a href="/Team/Create" class="btn btn-cyan btn-sm" style="margin-left:auto;">+ Lập Đội Mới</a>
  </div>
</div>
<div class="page-section">
  <div class="container">
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:16px;">
      @foreach (var t in Model)
      {
        bool isLQ = t.PrimaryGame == EsportManager.Models.GameType.LienQuan;
        <a href="/Team/Detail/@t.Id" class="team-card @(isLQ?"lq-team":"ff-team")">
          <div class="team-logo-hex">@(isLQ?"⚔":"🔥")</div>
          <div class="team-name-display">@t.Name</div>
          <div class="team-tag-display">[@t.Tag]</div>
          <div style="margin-bottom:10px;"><span class="chip @(isLQ?"chip-lq":"chip-ff")" style="font-size:10px;">@(isLQ?"LIÊN QUÂN":"FREE FIRE")</span></div>
          <div style="font-size:12px;color:var(--text-dim);margin-bottom:10px;">👑 @(t.Captain?.IngameName ?? t.Captain?.Username ?? "N/A")</div>
          <div class="team-stats-row">
            <div class="team-stat-item"><div class="val val-win">@t.Wins</div><div class="lbl">Win</div></div>
            <div class="team-stat-item"><div class="val val-loss">@t.Losses</div><div class="lbl">Loss</div></div>
            <div class="team-stat-item"><div class="val val-pts">@t.Points</div><div class="lbl">ELO</div></div>
          </div>
        </a>
      }
    </div>
  </div>
</div>
