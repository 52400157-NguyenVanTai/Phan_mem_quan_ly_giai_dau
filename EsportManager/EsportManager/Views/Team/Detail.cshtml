@* Team/Detail.cshtml *@
@model EsportManager.Models.Team
@{ViewData["Title"]="Đội – "+Model.Name; bool isLQ=Model.PrimaryGame==EsportManager.Models.GameType.LienQuan; string ac=isLQ?"var(--lq-gold)":"var(--ff-orange)"; var history=ViewBag.MatchHistory as List<EsportManager.Models.Match>; var regs=ViewBag.Registrations as List<EsportManager.Models.TournamentRegistration>;}
<div class="page-banner" style="border-bottom-color:@ac;">
  <div class="page-banner-inner">
    <div class="breadcrumb"><a href="/Team">Đội</a><span>/</span>@Model.Name</div>
    <div style="display:flex;align-items:center;gap:20px;margin-top:10px;">
      <div style="width:72px;height:72px;background:var(--bg-surface);clip-path:polygon(50% 0%,100% 25%,100% 75%,50% 100%,0% 75%,0% 25%);display:flex;align-items:center;justify-content:center;font-size:30px;">@(isLQ?"⚔":"🔥")</div>
      <div>
        <div style="display:flex;align-items:center;gap:10px;">
          <h1 style="font-size:28px;">@Model.Name</h1>
          <span class="chip @(isLQ?"chip-lq":"chip-ff")">[@Model.Tag]</span>
        </div>
        <p style="color:var(--text-dim);margin-top:4px;">@Model.Description</p>
        <div style="margin-top:8px;">
          <span class="chip @(isLQ?"chip-lq":"chip-ff")">@(isLQ?"⚔ LIÊN QUÂN":"🔥 FREE FIRE")</span>
          <span style="color:var(--text-dim);font-size:13px;margin-left:12px;">👑 @(Model.Captain?.IngameName??"N/A") · 🌏 @Model.Country</span>
        </div>
      </div>
      <div style="margin-left:auto;display:flex;gap:20px;">
        @{var ss=new[]{(Model.Points.ToString(),"ELO",ac),(Model.Wins.ToString(),"WIN","var(--success)"),(Model.Losses.ToString(),"LOSS","var(--danger)"),(Model.Wins+Model.Losses>0?$"{Model.Wins*100/(Model.Wins+Model.Losses)}%":"0%","WIN%","var(--cyan)")};}
        @foreach(var s in ss){<div style="text-align:center;"><div style="font-family:'Rajdhani',sans-serif;font-size:26px;font-weight:700;color:@s.Item3;">@s.Item1</div><div style="font-size:10px;color:var(--text-dim);letter-spacing:1px;text-transform:uppercase;">@s.Item2</div></div>}
      </div>
    </div>
  </div>
</div>
<div class="page-section">
  <div class="container">
    <div class="page-layout">
      <div>
        <div class="tabs-bar">
          <button class="tab-btn active" onclick="switchTab('tm-roster',this)">🎮 Roster</button>
          <button class="tab-btn" onclick="switchTab('tm-history',this)">⚡ Match History</button>
          <button class="tab-btn" onclick="switchTab('tm-tournaments',this)">🏆 Giải Đấu</button>
        </div>
        <div id="tm-roster" class="tab-pane active">
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
            <div style="padding:16px;background:@(isLQ?"rgba(255,193,7,0.05)":"rgba(255,87,34,0.05)");border:1px solid @(isLQ?"rgba(255,193,7,0.3)":"rgba(255,87,34,0.3)");border-radius:var(--radius);display:flex;align-items:center;gap:14px;">
              <div style="width:48px;height:48px;background:var(--bg-surface);clip-path:polygon(50% 0%,100% 25%,100% 75%,50% 100%,0% 75%,0% 25%);display:flex;align-items:center;justify-content:center;font-size:20px;">👤</div>
              <div>
                <div style="font-family:'Rajdhani',sans-serif;font-weight:700;font-size:16px;color:@ac;">@(Model.Captain?.IngameName??"N/A")</div>
                <div class="chip @(isLQ?"chip-lq":"chip-ff")" style="font-size:10px;margin-top:4px;">👑 CAPTAIN</div>
                <div style="font-size:12px;color:var(--text-dim);margin-top:3px;">@(isLQ?Model.Captain?.Rank_LQ:Model.Captain?.Rank_FF)</div>
              </div>
            </div>
            @for(int i=1;i<=4;i++){<div style="padding:16px;background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);display:flex;align-items:center;gap:14px;"><div style="width:48px;height:48px;background:var(--bg-surface);clip-path:polygon(50% 0%,100% 25%,100% 75%,50% 100%,0% 75%,0% 25%);display:flex;align-items:center;justify-content:center;font-size:20px;">👤</div><div><div style="font-family:'Rajdhani',sans-serif;font-weight:700;">Player @i</div><div class="chip chip-cyan" style="font-size:10px;margin-top:4px;">MEMBER</div><div style="font-size:12px;color:var(--text-dim);margin-top:3px;">@(isLQ?"Cao Thủ":"Heroic")</div></div></div>}
          </div>
          <div style="margin-top:14px;padding:16px;background:var(--bg-surface);border:1px dashed var(--border);border-radius:var(--radius);">
            <div style="font-size:13px;color:var(--text-dim);margin-bottom:10px;">📨 Mời thành viên (username / UID game)</div>
            <div style="display:flex;gap:8px;"><input class="form-input" placeholder="Username hoặc UID..." style="flex:1;" /><button class="btn btn-cyan btn-sm">Mời</button></div>
          </div>
        </div>
        <div id="tm-history" class="tab-pane">
          @if(history!=null&&history.Any()){@foreach(var m in history){bool w=m.WinnerId==Model.Id;<div class="match-card" style="border-left:3px solid @(w?"var(--success)":"var(--danger)")"><div style="min-width:44px;text-align:center;"><div style="font-family:'Rajdhani',sans-serif;font-size:12px;font-weight:700;color:@(w?"var(--success)":"var(--danger)");">@(w?"WIN":"LOSS")</div></div><div class="match-teams"><div class="match-team"><div class="match-team-name @(m.WinnerId==m.Team1Id?"winner":"")">@(m.Team1?.Name??"TBD")</div></div><div class="match-center"><div class="match-score-display">@m.Team1Score — @m.Team2Score</div><div class="match-round">@m.RoundName</div></div><div class="match-team"><div class="match-team-name @(m.WinnerId==m.Team2Id?"winner":"")">@(m.Team2?.Name??"TBD")</div></div></div><div style="font-size:12px;color:var(--text-dim);">@m.ScheduledAt.ToString("dd/MM/yyyy")</div></div>}}
          else{<div style="text-align:center;padding:40px;color:var(--text-dim);">Chưa có lịch sử thi đấu</div>}
        </div>
        <div id="tm-tournaments" class="tab-pane">
          @if(regs!=null&&regs.Any()){@foreach(var r in regs){var t=EsportManager.Services.MockData.Tournaments.FirstOrDefault(x=>x.Id==r.TournamentId);if(t!=null){<a href="/Tournament/Detail/@t.Id" style="display:flex;align-items:center;gap:14px;padding:14px;background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);color:var(--text-white);margin-bottom:10px;transition:all 0.2s;"><div style="font-size:28px;">@(t.Game==EsportManager.Models.GameType.LienQuan?"⚔️":"🔥")</div><div style="flex:1;"><div style="font-family:'Rajdhani',sans-serif;font-weight:700;">@t.Name</div><div style="font-size:12px;color:var(--text-dim);">@t.TournamentStart.ToString("dd/MM/yyyy")</div></div><span class="chip @(r.Status==EsportManager.Models.RegistrationStatus.Approved?"chip-green":r.Status==EsportManager.Models.RegistrationStatus.Pending?"chip-warn":"chip-red")">@r.Status</span></a>;}}}
          else{<div style="text-align:center;padding:40px;color:var(--text-dim);">Chưa tham gia giải đấu nào</div>}
        </div>
      </div>
      <div>
        <div class="widget mb-20">
          <div class="widget-head">📊 ELO & Stats</div>
          <div class="widget-body">
            <div style="text-align:center;padding:16px 0;border-bottom:1px solid var(--border);margin-bottom:14px;">
              <div style="font-family:'Rajdhani',sans-serif;font-size:40px;font-weight:700;color:@ac;">@Model.Points</div>
              <div style="font-size:11px;color:var(--text-dim);letter-spacing:2px;text-transform:uppercase;">ELO RATING</div>
              <div class="elo-progress mt-12" style="max-width:160px;margin:8px auto 0;"><div class="@(isLQ?"elo-fill-lq":"elo-fill-ff")" style="width:@(Math.Min(Model.Points/25,100))%;"></div></div>
            </div>
            @{var rs=new[]{("Tổng Trận",(Model.Wins+Model.Losses).ToString(),"var(--text-white)"),("Win Rate",Model.Wins+Model.Losses>0?$"{Model.Wins*100/(Model.Wins+Model.Losses)}%":"0%","var(--cyan)"),("Thành lập",Model.CreatedAt.ToString("MM/yyyy"),"var(--text-dim)")};} 
            @foreach(var r in rs){<div style="display:flex;justify-content:space-between;font-size:13px;padding:8px 0;border-top:1px solid rgba(0,229,255,0.05);"><span style="color:var(--text-dim);">@r.Item1</span><b style="color:@r.Item3;">@r.Item2</b></div>}
          </div>
        </div>
        <a href="/Tournament?status=Registration" class="btn @(isLQ?"btn-lq":"btn-ff") btn-full"><i class="fas fa-gamepad"></i> Đăng Ký Giải Mới</a>
      </div>
    </div>
  </div>
</div>
