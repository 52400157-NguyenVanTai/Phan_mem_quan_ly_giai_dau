@{
    ViewData["Title"] = "Bảng Xếp Hạng";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var lq = ViewBag.LQ as List<EsportManager.Models.Team>;
    var ff = ViewBag.FF as List<EsportManager.Models.Team>;
    string active = ViewBag.ActiveTab ?? "LienQuan";
    int maxLQ = lq != null && lq.Any() ? lq.Max(t => t.Points) : 1;
    int maxFF = ff != null && ff.Any() ? ff.Max(t => t.Points) : 1;
}
<div class="page-banner">
  <div class="page-banner-inner">
    <div class="breadcrumb"><a href="/">Home</a><span>/</span>Xếp Hạng</div>
    <h1><i class="fas fa-chart-bar" style="color:var(--cyan);margin-right:10px;"></i>BẢNG XẾP HẠNG ELO</h1>
    <p>Ranking các đội Liên Quân Mobile và Free Fire</p>
  </div>
</div>

<div class="page-section">
  <div class="container">

    <!-- GAME TABS -->
    <div class="tabs-bar">
      <button class="tab-btn @(active=="LienQuan"?"active":"")" onclick="switchTab('rk-lq',this)">⚔ Liên Quân Mobile</button>
      <button class="tab-btn @(active!="LienQuan"?"active":"")" onclick="switchTab('rk-ff',this)">🔥 Free Fire</button>
    </div>

    <!-- LQ RANKING -->
    <div id="rk-lq" class="tab-pane @(active=="LienQuan"?"active":"")">
      @if (lq != null && lq.Count >= 3)
      {
        <!-- PODIUM TOP 3 -->
        <div style="background:linear-gradient(135deg,rgba(255,193,7,0.06),rgba(0,229,255,0.03));border:1px solid rgba(255,193,7,0.2);border-radius:var(--radius);padding:32px;margin-bottom:28px;">
          <div style="text-align:center;margin-bottom:20px;font-family:'Rajdhani',sans-serif;font-size:13px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--lq-gold);">⚔ TOP LIÊN QUÂN MOBILE</div>
          <div style="display:flex;align-items:flex-end;justify-content:center;gap:16px;flex-wrap:wrap;">
            <!-- 2nd -->
            <div style="text-align:center;flex:1;max-width:180px;">
              <div style="font-size:40px;margin-bottom:8px;filter:drop-shadow(0 0 10px var(--lq-gold));">⚔️</div>
              <div style="background:rgba(158,158,158,0.1);border:1px solid rgba(158,158,158,0.3);border-top:3px solid #9e9e9e;border-radius:var(--radius-sm);padding:16px;">
                <div style="font-size:24px;margin-bottom:6px;">🥈</div>
                <div style="font-family:'Rajdhani',sans-serif;font-size:16px;font-weight:700;color:var(--text-white);">@lq[1].Name</div>
                <div class="chip chip-lq" style="font-size:10px;margin-top:4px;">[@lq[1].Tag]</div>
                <div style="font-family:'Rajdhani',sans-serif;font-size:22px;font-weight:700;color:#e0e0e0;margin-top:8px;">@lq[1].Points</div>
                <div style="font-size:11px;color:var(--text-dim);">@lq[1].Wins W — @lq[1].Losses L</div>
              </div>
            </div>
            <!-- 1st -->
            <div style="text-align:center;flex:1;max-width:200px;transform:translateY(-12px);">
              <div style="font-size:52px;margin-bottom:8px;filter:drop-shadow(0 0 20px var(--lq-gold));">⚔️</div>
              <div style="background:rgba(255,193,7,0.1);border:1px solid rgba(255,193,7,0.4);border-top:3px solid var(--lq-gold);border-radius:var(--radius-sm);padding:20px;">
                <div style="font-size:30px;margin-bottom:6px;">🥇</div>
                <div style="font-family:'Rajdhani',sans-serif;font-size:18px;font-weight:700;color:var(--lq-gold);">@lq[0].Name</div>
                <div class="chip chip-lq" style="font-size:10px;margin-top:4px;">[@lq[0].Tag]</div>
                <div style="font-family:'Rajdhani',sans-serif;font-size:28px;font-weight:700;color:var(--lq-gold);margin-top:8px;text-shadow:0 0 20px rgba(255,193,7,0.5);">@lq[0].Points</div>
                <div style="font-size:11px;color:var(--text-dim);">@lq[0].Wins W — @lq[0].Losses L</div>
              </div>
            </div>
            <!-- 3rd -->
            <div style="text-align:center;flex:1;max-width:180px;">
              <div style="font-size:40px;margin-bottom:8px;filter:drop-shadow(0 0 10px #cd7f32);">⚔️</div>
              <div style="background:rgba(205,127,50,0.1);border:1px solid rgba(205,127,50,0.3);border-top:3px solid #cd7f32;border-radius:var(--radius-sm);padding:16px;">
                <div style="font-size:24px;margin-bottom:6px;">🥉</div>
                <div style="font-family:'Rajdhani',sans-serif;font-size:16px;font-weight:700;color:var(--text-white);">@lq[2].Name</div>
                <div class="chip chip-lq" style="font-size:10px;margin-top:4px;">[@lq[2].Tag]</div>
                <div style="font-family:'Rajdhani',sans-serif;font-size:22px;font-weight:700;color:#e8a87c;margin-top:8px;">@lq[2].Points</div>
                <div style="font-size:11px;color:var(--text-dim);">@lq[2].Wins W — @lq[2].Losses L</div>
              </div>
            </div>
          </div>
        </div>
      }

      <div class="panel">
        <div class="panel-header"><span class="panel-title">⚔ FULL LEADERBOARD — LIÊN QUÂN MOBILE</span></div>
        <table class="rank-table">
          <thead><tr><th style="width:60px;">Hạng</th><th>Đội</th><th>Win</th><th>Loss</th><th>Win Rate</th><th>ELO / Điểm</th><th></th></tr></thead>
          <tbody>
            @{ int r=1; }
            @foreach (var t in lq ?? new())
            {
              int wr = (t.Wins+t.Losses)>0 ? t.Wins*100/(t.Wins+t.Losses) : 0;
              <tr>
                <td><div class="rank-num @(r==1?"rank-1":r==2?"rank-2":r==3?"rank-3":"")">@r</div></td>
                <td><a href="/Team/Detail/@t.Id" style="display:flex;align-items:center;gap:12px;color:var(--text-white);">
                  <div style="width:36px;height:36px;background:rgba(255,193,7,0.1);clip-path:polygon(50% 0%,100% 25%,100% 75%,50% 100%,0% 75%,0% 25%);display:flex;align-items:center;justify-content:center;font-size:16px;">⚔</div>
                  <div><div style="font-family:'Rajdhani',sans-serif;font-weight:700;font-size:15px;">@t.Name</div><div style="font-size:11px;color:var(--text-dim);">[@t.Tag] · @(t.Captain?.IngameName??"")</div></div>
                </a></td>
                <td style="font-family:'Rajdhani',sans-serif;font-weight:700;color:var(--success);font-size:16px;">@t.Wins</td>
                <td style="font-family:'Rajdhani',sans-serif;font-weight:700;color:var(--danger);font-size:16px;">@t.Losses</td>
                <td><div style="font-family:'Rajdhani',sans-serif;font-size:14px;font-weight:700;margin-bottom:4px;">@wr%</div><div class="elo-progress" style="width:80px;"><div class="elo-fill-lq" style="width:@wr%;"></div></div></td>
                <td><div style="font-family:'Rajdhani',sans-serif;font-size:20px;font-weight:700;color:var(--lq-gold);">@t.Points</div><div class="elo-progress mt-1" style="width:100px;"><div class="elo-fill-lq" style="width:@(t.Points*100/maxLQ)%;"></div></div></td>
                <td><a href="/Team/Detail/@t.Id" class="btn btn-lq btn-sm">Xem</a></td>
              </tr>
              r++;
            }
          </tbody>
        </table>
      </div>
    </div>

    <!-- FF RANKING -->
    <div id="rk-ff" class="tab-pane @(active!="LienQuan"?"active":"")">
      @if (ff != null && ff.Count >= 3)
      {
        <div style="background:linear-gradient(135deg,rgba(255,87,34,0.06),rgba(0,229,255,0.03));border:1px solid rgba(255,87,34,0.2);border-radius:var(--radius);padding:32px;margin-bottom:28px;">
          <div style="text-align:center;margin-bottom:20px;font-family:'Rajdhani',sans-serif;font-size:13px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--ff-orange);">🔥 TOP FREE FIRE</div>
          <div style="display:flex;align-items:flex-end;justify-content:center;gap:16px;flex-wrap:wrap;">
            <div style="text-align:center;flex:1;max-width:180px;">
              <div style="font-size:40px;margin-bottom:8px;filter:drop-shadow(0 0 10px var(--ff-orange));">🔥</div>
              <div style="background:rgba(158,158,158,0.1);border:1px solid rgba(158,158,158,0.3);border-top:3px solid #9e9e9e;border-radius:var(--radius-sm);padding:16px;">
                <div style="font-size:24px;margin-bottom:6px;">🥈</div>
                <div style="font-family:'Rajdhani',sans-serif;font-size:16px;font-weight:700;">@ff[1].Name</div>
                <div class="chip chip-ff" style="font-size:10px;margin-top:4px;">[@ff[1].Tag]</div>
                <div style="font-family:'Rajdhani',sans-serif;font-size:22px;font-weight:700;color:#e0e0e0;margin-top:8px;">@ff[1].Points</div>
              </div>
            </div>
            <div style="text-align:center;flex:1;max-width:200px;transform:translateY(-12px);">
              <div style="font-size:52px;margin-bottom:8px;filter:drop-shadow(0 0 20px var(--ff-orange));">🔥</div>
              <div style="background:rgba(255,87,34,0.1);border:1px solid rgba(255,87,34,0.4);border-top:3px solid var(--ff-orange);border-radius:var(--radius-sm);padding:20px;">
                <div style="font-size:30px;margin-bottom:6px;">🥇</div>
                <div style="font-family:'Rajdhani',sans-serif;font-size:18px;font-weight:700;color:var(--ff-orange);">@ff[0].Name</div>
                <div class="chip chip-ff" style="font-size:10px;margin-top:4px;">[@ff[0].Tag]</div>
                <div style="font-family:'Rajdhani',sans-serif;font-size:28px;font-weight:700;color:var(--ff-orange);margin-top:8px;text-shadow:0 0 20px rgba(255,87,34,0.5);">@ff[0].Points</div>
              </div>
            </div>
            <div style="text-align:center;flex:1;max-width:180px;">
              <div style="font-size:40px;margin-bottom:8px;filter:drop-shadow(0 0 10px #cd7f32);">🔥</div>
              <div style="background:rgba(205,127,50,0.1);border:1px solid rgba(205,127,50,0.3);border-top:3px solid #cd7f32;border-radius:var(--radius-sm);padding:16px;">
                <div style="font-size:24px;margin-bottom:6px;">🥉</div>
                <div style="font-family:'Rajdhani',sans-serif;font-size:16px;font-weight:700;">@ff[2].Name</div>
                <div class="chip chip-ff" style="font-size:10px;margin-top:4px;">[@ff[2].Tag]</div>
                <div style="font-family:'Rajdhani',sans-serif;font-size:22px;font-weight:700;color:#e8a87c;margin-top:8px;">@ff[2].Points</div>
              </div>
            </div>
          </div>
        </div>
      }
      <div class="panel">
        <div class="panel-header"><span class="panel-title">🔥 FULL LEADERBOARD — FREE FIRE</span></div>
        <table class="rank-table">
          <thead><tr><th style="width:60px;">Hạng</th><th>Đội</th><th>Win</th><th>Loss</th><th>Win Rate</th><th>ELO / Điểm</th><th></th></tr></thead>
          <tbody>
            @{ int r2=1; }
            @foreach (var t in ff ?? new())
            {
              int wr = (t.Wins+t.Losses)>0 ? t.Wins*100/(t.Wins+t.Losses) : 0;
              <tr>
                <td><div class="rank-num @(r2==1?"rank-1":r2==2?"rank-2":r2==3?"rank-3":"")">@r2</div></td>
                <td><a href="/Team/Detail/@t.Id" style="display:flex;align-items:center;gap:12px;color:var(--text-white);">
                  <div style="width:36px;height:36px;background:rgba(255,87,34,0.1);clip-path:polygon(50% 0%,100% 25%,100% 75%,50% 100%,0% 75%,0% 25%);display:flex;align-items:center;justify-content:center;font-size:16px;">🔥</div>
                  <div><div style="font-family:'Rajdhani',sans-serif;font-weight:700;font-size:15px;">@t.Name</div><div style="font-size:11px;color:var(--text-dim);">[@t.Tag] · @(t.Captain?.IngameName??"")</div></div>
                </a></td>
                <td style="font-family:'Rajdhani',sans-serif;font-weight:700;color:var(--success);font-size:16px;">@t.Wins</td>
                <td style="font-family:'Rajdhani',sans-serif;font-weight:700;color:var(--danger);font-size:16px;">@t.Losses</td>
                <td><div style="font-family:'Rajdhani',sans-serif;font-size:14px;font-weight:700;margin-bottom:4px;">@wr%</div><div class="elo-progress" style="width:80px;"><div class="elo-fill-ff" style="width:@wr%;"></div></div></td>
                <td><div style="font-family:'Rajdhani',sans-serif;font-size:20px;font-weight:700;color:var(--ff-orange);">@t.Points</div><div class="elo-progress mt-1" style="width:100px;"><div class="elo-fill-ff" style="width:@(t.Points*100/maxFF)%;"></div></div></td>
                <td><a href="/Team/Detail/@t.Id" class="btn btn-ff btn-sm">Xem</a></td>
              </tr>
              r2++;
            }
          </tbody>
        </table>
      </div>
    </div>

  </div>
</div>
