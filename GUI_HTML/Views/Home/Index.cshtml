@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>EsportHub — Nền tảng Quản lý Giải đấu</title>
    <link rel="stylesheet" href="~/Content/esport.css" />
</head>
<body class="public-page">

<!-- ====== TOP TASKBAR (Public) ====== -->
<nav class="public-topbar">
    <a href="/" class="public-logo">⚡ ESPORT HUB</a>
    <div class="public-nav-links">
        <a href="#featured-tourneys" class="public-nav-link">Giải đấu</a>
        <a href="#game-pool" class="public-nav-link">Game</a>
        <a href="#featured-teams" class="public-nav-link">Đội tuyển</a>
        <a href="#how-it-works" class="public-nav-link">Về nền tảng</a>
    </div>
    <div style="flex:1"></div>
    <div class="public-topbar-actions">
        <a href="/login" class="btn-nav-login">Đăng nhập</a>
        <a href="/login?tab=register" class="btn-nav-register">Đăng ký</a>
    </div>
</nav>

<!-- ====== PUBLIC HOMEPAGE ====== -->
<main class="public-body">
    <section class="public-hero">
        <div class="hero-bg-depth"></div>
        <canvas class="hero-particles-canvas" id="hero-particles-canvas" aria-hidden="true"></canvas>
        <div class="hero-overlay-grid"></div>
        <div class="hero-vignette"></div>
        <div class="hero-glow hero-glow-left"></div>
        <div class="hero-glow hero-glow-right"></div>

        <div class="public-container hero-layout">
            <div class="hero-content">
                <div class="hero-kicker">Nền tảng quản lý giải đấu esports</div>
                <h1 class="hero-title">
                    Kết nối đội tuyển, vận hành giải đấu,
                    <span>thổi bùng khí chất thi đấu chuyên nghiệp.</span>
                </h1>
                <p class="hero-subtitle">
                    ESPORT HUB giúp bạn tổ chức, theo dõi và tham gia hệ sinh thái thi đấu từ vòng loại đến chung kết.
                    Lịch đấu, bracket, đội hình và kết quả được quản lý tập trung, rõ ràng và sẵn sàng cho cộng đồng.
                </p>

                <div class="hero-cta-row">
                    <a href="#featured-tourneys" class="btn-hero-primary">Khám phá giải đấu</a>
                    <a href="/login?tab=register" class="btn-hero-secondary">Tạo giải đấu</a>
                </div>

                <div class="hero-stats-row">
                    <div class="hero-stat-card">
                        <div class="hero-stat-value" id="hero-stat-active-tournaments">--</div>
                        <div class="hero-stat-label">Giải đấu đang hoạt động</div>
                    </div>
                    <div class="hero-stat-card">
                        <div class="hero-stat-value" id="hero-stat-active-teams">--</div>
                        <div class="hero-stat-label">Đội tuyển tham gia</div>
                    </div>
                    <div class="hero-stat-card">
                        <div class="hero-stat-value" id="hero-stat-supported-games">--</div>
                        <div class="hero-stat-label">Game hỗ trợ</div>
                    </div>
                </div>
            </div>

            <div class="hero-showcase">
                <div class="hero-showcase-panel" id="hero-match-panel">
                    <div class="showcase-head">
                        <span class="showcase-badge live">DỮ LIỆU TRẬN ĐẤU</span>
                        <span class="showcase-time" id="hero-match-time">Đang đồng bộ từ hệ thống</span>
                    </div>
                    <h3 id="hero-match-title">Chưa có trận đấu khả dụng</h3>
                    <div class="showcase-match">
                        <div class="team-slot">
                            <span class="team-mark" id="hero-match-team-a-mark">--</span>
                            <span class="team-name" id="hero-match-team-a-name">Đội A</span>
                        </div>
                        <span class="team-score" id="hero-match-status">N/A</span>
                        <div class="team-slot">
                            <span class="team-mark" id="hero-match-team-b-mark">--</span>
                            <span class="team-name" id="hero-match-team-b-name">Đội B</span>
                        </div>
                    </div>
                    <div class="showcase-meta-row" id="hero-match-meta-row">
                        <span id="hero-match-meta-left">Chưa có dữ liệu vòng đấu</span>
                        <span id="hero-match-meta-right">Số liệu theo dõi lấy từ hệ thống</span>
                    </div>
                </div>

                <div class="hero-showcase-minirow">
                    <div class="hero-mini-card">
                        <div class="mini-label">Mở đăng ký</div>
                        <div class="mini-title" id="hero-open-title">Đang tải...</div>
                        <div class="mini-meta" id="hero-open-meta">Dữ liệu giải mở đăng ký</div>
                    </div>
                    <div class="hero-mini-card">
                        <div class="mini-label">Sắp diễn ra</div>
                        <div class="mini-title" id="hero-upcoming-title">Đang tải...</div>
                        <div class="mini-meta" id="hero-upcoming-meta">Dữ liệu lịch khởi tranh</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="public-section" id="featured-tourneys">
        <div class="public-container">
            <div class="section-heading-row">
                <div>
                    <div class="section-kicker">Giải đấu nổi bật</div>
                    <h2 class="section-title">Các giải được ưu tiên theo trạng thái vận hành thực</h2>
                </div>
                <a href="/login" class="section-link">Xem toàn bộ</a>
            </div>

            <div class="public-grid tournament-grid" id="featured-tournaments-list">
                <article class="public-card loading-card">Đang tải giải đấu nổi bật từ cơ sở dữ liệu...</article>
            </div>
        </div>
    </section>

    <section class="public-section" id="game-pool">
        <div class="public-container">
            <div class="section-heading-row">
                <div>
                    <div class="section-kicker">Game hệ thống hỗ trợ</div>
                    <h2 class="section-title">Danh mục game active trong hệ thống</h2>
                </div>
            </div>

            <div class="public-grid game-grid" id="supported-games-list">
                <article class="public-card loading-card">Đang tải danh sách game...</article>
            </div>
        </div>
    </section>

    <section class="public-section" id="featured-teams">
        <div class="public-container">
            <div class="section-heading-row">
                <div>
                    <div class="section-kicker">Đội tuyển & cộng đồng</div>
                    <h2 class="section-title">Những team đang hoạt động nổi bật</h2>
                </div>
                <a href="/login" class="section-link">Khám phá đội tuyển</a>
            </div>

            <div class="public-grid team-grid" id="featured-teams-list">
                <article class="public-card loading-card">Đang tải đội tuyển nổi bật...</article>
            </div>
        </div>
    </section>

    <section class="public-section" id="public-registration-blocks">
        <div class="public-container">
            <div class="section-heading-row">
                <div>
                    <div class="section-kicker">Đăng ký & lịch khởi tranh</div>
                    <h2 class="section-title">Các giải mở đăng ký và sắp diễn ra theo dữ liệu thời gian thực</h2>
                </div>
            </div>

            <div class="public-grid dual-column-grid">
                <div class="public-card">
                    <h3 class="column-title">Mở đăng ký</h3>
                    <div class="stacked-list" id="open-registration-list">
                        <div class="loading-line">Đang tải danh sách mở đăng ký...</div>
                    </div>
                </div>
                <div class="public-card">
                    <h3 class="column-title">Sắp diễn ra</h3>
                    <div class="stacked-list" id="upcoming-tournaments-list">
                        <div class="loading-line">Đang tải danh sách sắp diễn ra...</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="public-section" id="public-live-matches">
        <div class="public-container">
            <div class="section-heading-row">
                <div>
                    <div class="section-kicker">Trận đấu gần nhất / đang đấu</div>
                    <h2 class="section-title">Chỉ hiển thị khi hệ thống có dữ liệu trận thật</h2>
                </div>
            </div>

            <div class="public-grid matches-grid" id="live-matches-list">
                <article class="public-card loading-card">Đang tải dữ liệu trận đấu...</article>
            </div>
        </div>
    </section>

    <section class="public-section" id="how-it-works">
        <div class="public-container">
            <div class="section-heading-row">
                <div>
                    <div class="section-kicker">Cách nền tảng hoạt động</div>
                    <h2 class="section-title">3 bước để bước vào hệ sinh thái thi đấu</h2>
                </div>
            </div>

            <div class="public-grid steps-grid">
                <article class="public-card step-card">
                    <div class="step-index">01</div>
                    <h3>Tạo hồ sơ đội hoặc tuyển thủ</h3>
                    <p>Thiết lập thông tin, đội hình và vai trò để sẵn sàng tham gia giải.</p>
                </article>
                <article class="public-card step-card">
                    <div class="step-index">02</div>
                    <h3>Đăng ký vào giải phù hợp</h3>
                    <p>Chọn game, bracket và theo dõi lịch thi đấu được cập nhật theo thời gian thực.</p>
                </article>
                <article class="public-card step-card">
                    <div class="step-index">03</div>
                    <h3>Thi đấu và theo dõi kết quả</h3>
                    <p>Quản lý trận đấu, điểm số và hành trình tiến sâu trong hệ thống minh bạch.</p>
                </article>
            </div>
        </div>
    </section>

    <section class="public-section public-final-cta">
        <div class="public-container">
            <div class="final-cta-card">
                <h2>Sẵn sàng bước vào đấu trường của ESPORT HUB?</h2>
                <p>Tham gia cộng đồng thi đấu, khám phá giải đang mở đăng ký hoặc tạo sân chơi của riêng bạn ngay hôm nay.</p>
                <div class="final-cta-actions">
                    <a href="/login?tab=register" class="btn-hero-primary">Bắt đầu ngay</a>
                    <a href="/login" class="btn-hero-secondary">Đăng nhập hệ thống</a>
                </div>
            </div>
        </div>
    </section>
</main>

<script src="~/Scripts/home-hero-particles.js"></script>
<script src="~/Scripts/home-public.js"></script>
</body>
</html>
