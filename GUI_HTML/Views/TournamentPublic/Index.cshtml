@{
    ViewBag.Title = "Cổng thông tin giải đấu";
    var maGiaiDau = (int)ViewBag.MaGiaiDau;
}

<div class="container py-4" data-ma-giai-dau="@maGiaiDau" id="public-tournament-root">
    <div id="public-alert" class="alert d-none" role="alert"></div>

    <div class="mb-4">
        <h2 id="public-title" class="mb-1">Giải đấu</h2>
        <p id="public-meta" class="text-muted mb-0"></p>
        <div id="public-live-status" class="small text-success mt-1">Live Engine đang kết nối...</div>
    </div>

    <ul id="stage-tabs" class="nav nav-tabs mb-3"></ul>

    <div class="card">
        <div class="card-body">
            <div id="stage-content"></div>
        </div>
    </div>

    <div class="card mt-3">
        <div class="card-body">
            <h5 class="mb-3">Vinh danh tự động</h5>
            <div id="honoring-content" class="small text-muted">Đang tải dữ liệu vinh danh...</div>
        </div>
    </div>
</div>

@section scripts {
    <script src="~/Scripts/tournament-public.js"></script>
}
