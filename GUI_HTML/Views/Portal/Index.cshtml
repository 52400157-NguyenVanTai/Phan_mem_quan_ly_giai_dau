@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dashboard — EsportHub</title>
    <link rel="stylesheet" href="~/Content/esport.css" />
</head>
<body>

<!-- ============================================================
     APP SHELL — Dashboard (Private Layout)
============================================================ -->
<div id="app-shell" class="active">

    <!-- SIDEBAR -->
    <nav id="sidebar">
        <div class="sidebar-logo">
            <div class="sidebar-logo-text">⚡ ESPORT HUB</div>
            <div class="sidebar-logo-sub">Tournament Platform</div>
        </div>

        <div class="sidebar-section">
            <div class="sidebar-section-label">Điều hướng</div>
            <button class="sidebar-item active" data-page="home" onclick="navigateTo('home')">
                <span class="si-icon">🏠</span> Trang chủ
            </button>
            <div class="sidebar-divider"></div>
            <div class="sidebar-section-label" style="padding:8px 8px 4px">Game</div>
            <button class="sidebar-item" data-page="game-aov" onclick="navigateTo('game-aov')">
                <span class="si-icon">🎮</span><span style="color:#ffa502" class="game-dot"></span> Arena of Valor
            </button>
            <button class="sidebar-item" data-page="game-lol" onclick="navigateTo('game-lol')">
                <span class="si-icon">🎮</span><span style="color:#6c63ff" class="game-dot"></span> League of Legends
            </button>
            <button class="sidebar-item" data-page="game-ff" onclick="navigateTo('game-ff')">
                <span class="si-icon">🎮</span><span style="color:#ff4757" class="game-dot"></span> Free Fire
            </button>
            <button class="sidebar-item" data-page="game-pubg" onclick="navigateTo('game-pubg')">
                <span class="si-icon">🎮</span><span style="color:#ffd700" class="game-dot"></span> PUBG
            </button>
            <button class="sidebar-item" data-page="game-val" onclick="navigateTo('game-val')">
                <span class="si-icon">🎮</span><span style="color:#ff4655" class="game-dot"></span> Valorant
            </button>
            <button class="sidebar-item" data-page="game-cs2" onclick="navigateTo('game-cs2')">
                <span class="si-icon">🎮</span><span style="color:#f0a500" class="game-dot"></span> CS2
            </button>
            <div class="sidebar-divider"></div>
            <button class="sidebar-item" data-page="follow" onclick="navigateTo('follow')">
                <span class="si-icon">❤️</span> Theo dõi
            </button>
            <button class="sidebar-item" data-page="notifications" onclick="navigateTo('notifications')">
                <span class="si-icon">🔔</span> Bảng thông báo
                <span class="si-badge" id="sidebar-notif-count" style="display:none">0</span>
            </button>
            <button class="sidebar-item" id="side-my-tournaments" data-page="my-tournaments" onclick="navigateTo('my-tournaments')">
                <span class="si-icon">🏆</span> Giải đấu của tôi
            </button>
            <button class="sidebar-item" id="side-my-teams" data-page="my-teams" onclick="navigateTo('my-teams')">
                <span class="si-icon">👥</span> Đội của tôi
            </button>
            <button class="sidebar-item" data-page="team-explorer" onclick="navigateTo('team-explorer')">
                <span class="si-icon">🔍</span> Khám phá đội
            </button>
            <button class="sidebar-item d-none" id="btn-admin-module" data-page="admin-requests" onclick="navigateTo('admin-requests')">
                <span class="si-icon">⚙️</span> Yêu cầu Admin
            </button>
            <button class="sidebar-item" data-page="referee-center" onclick="navigateTo('referee-center')">
                <span class="si-icon">🧑‍⚖️</span> Trung tâm Trọng tài
            </button>
        </div>
    </nav>

    <!-- MAIN AREA -->
    <div id="main-area">

        <!-- TOPBAR -->
        <header id="topbar">
            <button id="sidebar-toggle" class="topbar-btn" onclick="toggleSidebar()" title="Menu">☰</button>
            <div class="search-wrap" style="position:relative">
                <span class="search-icon">🔍</span>
                <input id="global-search" type="text" placeholder="Tìm kiếm giải đấu, đội, game..." autocomplete="off" />
                <div id="search-dropdown" class="search-dropdown" style="display:none"></div>
            </div>
            <div class="topbar-spacer"></div>
            <div class="topbar-actions">
                <button class="topbar-btn" onclick="navigateTo('notifications')" title="Thông báo" id="notif-btn">
                    🔔
                    <span class="notif-dot" id="notif-dot" style="display:none"></span>
                </button>
                <div class="avatar-btn" id="avatar-btn" onclick="navigateTo('profile')" title="Hồ sơ cá nhân">
                    <span id="avatar-initials">?</span>
                </div>
                <div class="hamburger-menu-wrap">
                    <button class="topbar-btn" id="hamburger-btn" onclick="toggleHamburger()" title="Menu">≡</button>
                    <div class="dropdown-menu-custom" id="hamburger-menu">
                        <button class="dropdown-item-custom" onclick="navigateTo('profile');toggleHamburger()">
                            👤 Thông tin cá nhân
                        </button>
                        <button class="dropdown-item-custom" onclick="navigateTo('player-profile');toggleHamburger()">
                            🎮 Hồ sơ thi đấu
                        </button>
                        <button class="dropdown-item-custom" onclick="navigateTo('my-teams');toggleHamburger()">
                            👥 Đội của tôi
                        </button>
                        <button class="dropdown-item-custom" onclick="navigateTo('team-explorer');toggleHamburger()">
                            🔍 Khám phá đội
                        </button>
                        <div class="dropdown-divider"></div>
                        <button class="dropdown-item-custom danger" onclick="doLogout()">
                            🚪 Đăng xuất
                        </button>
                    </div>
                </div>
            </div>
        </header>

        <!-- CONTENT AREA -->
        <div id="content-area">
            <div id="global-alert" class="alert d-none" role="alert" style="margin-bottom:12px"></div>

            <!-- HOME PAGE -->
            <div id="page-home" class="page-section">
                <div class="page-title">Chào mừng! 👋</div>
                <p class="page-sub">Khám phá giải đấu, lập đội và chinh phục đỉnh cao.</p>
                <div class="action-btns">
                    <button class="btn-primary-glow" onclick="navigateTo('organize')">🏆 Tổ chức giải đấu</button>
                    <button class="btn-outline-glow" onclick="navigateTo('create-team')">👥 Tạo đội</button>
                    <button class="btn-outline-glow" onclick="navigateTo('team-explorer')">🔍 Tìm đội</button>
                </div>
                <div class="section-title">🔥 Giải đấu nổi bật</div>
                <div class="tournament-grid" id="featured-grid"></div>
                <div class="section-title">📅 Sắp bắt đầu</div>
                <div class="tournament-grid" id="upcoming-grid"></div>
                <div class="section-title">📝 Đang mở đăng ký</div>
                <div class="tournament-grid" id="open-reg-grid"></div>
            </div>

            <!-- GAME PAGES -->
            <div id="page-game" class="page-section" style="display:none">
                <div class="page-title" id="game-page-title">Game</div>
                <p class="page-sub" id="game-page-sub">Các giải đấu nổi bật</p>
                <div class="filter-bar">
                    <select class="select-dark" id="game-status-filter" onchange="applyGameFilter()" style="min-width:180px">
                        <option value="">Tất cả trạng thái</option>
                        <option value="mo_dang_ky">Mở đăng ký</option>
                        <option value="sap_dien_ra">Sắp diễn ra</option>
                        <option value="dang_dien_ra">Đang diễn ra</option>
                        <option value="ket_thuc">Kết thúc</option>
                    </select>
                    <input class="form-control-dark" id="game-search" placeholder="Tìm trong game..." style="max-width:260px" />
                </div>
                <div class="tournament-grid" id="game-grid"></div>
            </div>

            <!-- FOLLOW PAGE -->
            <div id="page-follow" class="page-section" style="display:none">
                <div class="page-title">❤️ Đang theo dõi</div>
                <p class="page-sub">Các giải đấu bạn đang theo dõi</p>
                <div class="tournament-grid" id="follow-grid"></div>
            </div>

            <!-- NOTIFICATIONS PAGE -->
            <div id="page-notifications" class="page-section" style="display:none">
                <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px">
                    <div>
                        <div class="page-title">🔔 Thông báo</div>
                        <p class="page-sub">Cập nhật mới nhất từ hệ thống</p>
                    </div>
                    <button class="btn-outline-glow" onclick="markAllRead()" style="font-size:.85rem;padding:6px 14px">Đánh dấu tất cả đã đọc</button>
                </div>
                <div id="notif-list"></div>
            </div>

            <!-- MY TOURNAMENTS -->
            <div id="page-my-tournaments" class="page-section" style="display:none">
                <div class="page-title">🏆 Giải đấu của tôi</div>
                <p class="page-sub">Quản lý giải đấu cá nhân</p>
                <div class="action-btns">
                    <button class="btn-primary-glow" onclick="navigateTo('organize')">+ Tổ chức giải mới</button>
                </div>
                <div class="tab-bar" id="my-tournaments-tabs">
                    <button class="tab-btn active" onclick="switchMyTournamentTab('created')" id="mt-tab-created">Giải đã tạo</button>
                    <button class="tab-btn" onclick="switchMyTournamentTab('joined')" id="mt-tab-joined">Giải đã tham gia</button>
                </div>
                <div class="tournament-grid" id="my-tournaments-grid"></div>
            </div>

            <!-- MANAGE TOURNAMENT -->
            <div id="page-manage-tournament" class="page-section" style="display:none">
                <button class="btn-outline-glow" style="margin-bottom:15px; padding: 4px 12px; font-size: 0.9rem" onclick="navigateTo('my-tournaments')">← Quay lại</button>
                <div class="page-title" id="manage-tour-name">Quản lý Giải đấu</div>
                <div class="mb-3" id="manage-tour-status"></div>
                <p id="manage-tour-msg" style="margin-bottom: 10px"></p>
                
                <div class="profile-card" style="margin-bottom: 20px" id="manage-tour-actions">
                    <!-- Buttons will be injected here -->
                </div>

                <h5>Các giai đoạn thi đấu</h5>
                <div class="profile-card" style="margin-bottom: 20px">
                    <div id="manage-stage-list" style="margin-bottom: 15px"></div>
                    <div id="manage-add-stage-area" style="border-top: 1px solid var(--border); padding-top: 15px;">
                        <h6>Thêm giai đoạn mới</h6>
                        <div style="display:flex; gap:10px; margin-top: 10px; flex-wrap:wrap">
                            <input type="text" id="manage-stage-name" class="form-control-dark" placeholder="Tên giai đoạn (Vòng bảng, Playoff...)" style="flex:2" />
                            <select id="manage-stage-format" class="select-dark" style="flex:2">
                                <option value="loai_truc_tiep">Loại trực tiếp (Single Elim)</option>
                                <option value="nhanh_thang_nhanh_thua">Nhánh thắng / Nhánh thua</option>
                                <option value="vong_tron">Đấu vòng tròn</option>
                                <option value="thuy_si">Hệ Thụy Sĩ (Swiss)</option>
                                <option value="champion_rush">Champion Rush</option>
                            </select>
                            <input type="number" id="manage-stage-teams" class="form-control-dark" placeholder="Số đội đi tiếp" min="1" value="2" style="flex:1"/>
                        </div>
                        <button class="btn-primary-glow" style="margin-top:10px" onclick="submitAddStage()">+ Thêm giai đoạn</button>
                    </div>
                </div>
            </div>


            <!-- MY TEAMS (Workspace) -->
            <div id="page-my-teams" class="page-section" style="display:none">
                <!-- Breadcrumb -->
                <div class="mt-breadcrumb" id="mt-breadcrumb">Trang chủ / Đội / <span id="mt-team-name-bc">...</span></div>

                <!-- Team Header -->
                <div class="mt-header" id="mt-header">
                    <div class="mt-header-left">
                        <div class="mt-logo" id="mt-logo" onclick="triggerTeamLogoUpload()" style="cursor:pointer" title="Click để đổi logo đội">⚔</div>
                        <div class="mt-info">
                            <div class="mt-title-row">
                                <h2 id="mt-team-name">Đang tải...</h2>
                            </div>
                            <p class="mt-slogan" id="mt-slogan"></p>
                            <div class="mt-meta-badges" id="mt-meta-badges"></div>
                        </div>
                    </div>
                </div>

                <!-- Hidden file input for team logo upload -->
                <input type="file" id="team-logo-file-input" accept="image/*" style="display:none">

                <!-- Squad Filter (game tabs) -->
                <div class="mt-squad-filter" id="mt-squad-filter"></div>

                <!-- Main Layout: Content + Sidebar -->
                <div class="mt-layout">
                    <div class="mt-main">
                        <!-- 4 Tabs -->
                        <div class="mt-tabs" id="mt-tabs">
                            <button class="mt-tab active" data-tab="roster" onclick="switchMyTeamTab('roster', this)">🎖 ROSTER</button>
                            <button class="mt-tab" data-tab="history" onclick="switchMyTeamTab('history', this)">⚡ LỊCH SỬ THI ĐẤU</button>
                            <button class="mt-tab" data-tab="tournaments" onclick="switchMyTeamTab('tournaments', this)">🏆 GIẢI ĐẤU</button>
                            <button class="mt-tab" data-tab="stats" onclick="switchMyTeamTab('stats', this)">📊 THỐNG KÊ</button>
                        </div>
                        <!-- Tab Content -->
                        <div id="mt-tab-content"></div>
                        <!-- Squad Join Requests (visible for captain on roster tab) -->
                        <div id="mt-join-requests-section" style="display:none">
                            <div class="mt-invite-box">
                                <div class="mt-invite-title">📋 Yêu cầu tham gia nhóm</div>
                                <div id="mt-join-requests-list" style="margin-top:10px"></div>
                            </div>
                        </div>
                        <!-- Invite Member (visible for leader/captain on roster tab) -->
                        <div id="mt-invite-section" style="display:none">
                            <div class="mt-invite-box">
                                <div class="mt-invite-title">📨 Mời thành viên mới</div>
                                <div class="form-group-dark" style="margin-bottom:8px">
                                    <label>Chọn nhóm (tùy chọn)</label>
                                    <select class="select-dark" id="mt-invite-squad">
                                        <option value="">Chỉ mời vào đội (chưa phân nhóm)</option>
                                    </select>
                                </div>
                                <div class="mt-invite-row">
                                    <input class="form-control-dark" id="mt-invite-input" placeholder="Biệt danh / ID người chơi..." />
                                    <button class="btn-primary-glow" onclick="submitInviteMember()">MỜI</button>
                                </div>
                                <span id="mt-invite-msg" style="font-size:.82rem;margin-top:6px;display:block"></span>
                            </div>
                        </div>
                    </div>
                    <!-- Right Sidebar -->
                    <div class="mt-sidebar" id="mt-sidebar">
                        <div class="mt-sidebar-card" id="mt-sidebar-info"></div>
                        <div class="mt-sidebar-actions">
                            <button class="btn-primary-glow" style="width:100%" onclick="navigateTo('team-explorer')">🏆 Đăng ký giải đấu</button>
                            <button class="btn-outline-glow" style="width:100%;margin-top:8px" id="mt-btn-add-squad" onclick="toggleMyTeamAddSquad()">➕ Thêm nhóm thi đấu</button>
                            <button class="btn-outline-glow" style="width:100%;margin-top:8px" id="mt-btn-delete-squad" onclick="deleteSelectedMyTeamSquad()">🗑️ Xóa nhóm đang chọn</button>
                            <button class="btn-outline-glow" style="width:100%;margin-top:8px;border-color:#ff4757;color:#ff6b81" id="mt-btn-delete-team" onclick="deleteMyTeam()">❌ Xóa đội</button>
                        </div>
                        <!-- Add Squad Form (hidden) -->
                        <div id="mt-add-squad-form" style="display:none" class="mt-sidebar-card">
                            <h6>Thêm nhóm mới</h6>
                            <div class="form-group-dark" style="margin-bottom:8px">
                                <label>Game</label>
                                <select class="select-dark" id="mt-add-squad-game"></select>
                            </div>
                            <div class="form-group-dark" style="margin-bottom:8px">
                                <label>Tên nhóm</label>
                                <input class="form-control-dark" id="mt-add-squad-name" placeholder="VD: Đội hình chính LoL" />
                            </div>
                            <button class="btn-save" style="width:100%" onclick="submitMyTeamAddSquad()">Tạo nhóm</button>
                            <span id="mt-add-squad-msg" style="font-size:.82rem;margin-top:6px;display:block"></span>
                        </div>
                    </div>
                </div>

                <!-- Empty state (when not in any team) -->
                <div id="mt-empty" style="display:none">
                    <div class="empty-state" style="padding:60px 20px">
                        <div class="empty-state-icon">👥</div>
                        <h4>Chưa thuộc đội nào</h4>
                        <p>Hãy tạo đội mới hoặc tìm kiếm và gia nhập một đội!</p>
                        <div style="margin-top:16px;display:flex;gap:12px;justify-content:center">
                            <button class="btn-primary-glow" onclick="navigateTo('create-team')">+ Tạo đội mới</button>
                            <button class="btn-outline-glow" onclick="navigateTo('team-explorer')">🔍 Tìm đội</button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- TEAM EXPLORER -->
            <div id="page-team-explorer" class="page-section" style="display:none">
                <div class="page-title">🔍 Khám phá đội tuyển</div>
                <p class="page-sub">Tìm kiếm và tham gia các đội tuyển</p>
                <div class="filter-bar">
                    <select class="select-dark" id="te-game-filter" onchange="loadTeamExplorer()" style="min-width:160px">
                        <option value="">Tất cả game</option>
                    </select>
                    <label style="display:flex;align-items:center;gap:6px;color:var(--text-muted);font-size:.85rem">
                        <input type="checkbox" id="te-recruit-filter" onchange="loadTeamExplorer()" /> Đang tuyển
                    </label>
                    <input class="form-control-dark" id="te-search" placeholder="Tìm tên đội..." style="max-width:240px" />
                    <button class="btn-primary-glow" onclick="loadTeamExplorer()" style="padding:6px 16px">Tìm</button>
                </div>
                <div id="team-explorer-grid" class="team-grid"></div>
            </div>

            <!-- TEAM DETAIL -->
            <div id="page-team-detail" class="page-section" style="display:none">
                <button class="btn-outline-glow" onclick="navigateTo('team-explorer')" style="margin-bottom:12px;padding:4px 12px;font-size:.9rem">← Quay lại</button>
                <div id="team-detail-header"></div>
                <div class="tab-bar" id="team-squad-tabs"></div>
                <div id="team-squad-content"></div>
            </div>

            <!-- ORGANIZE (placeholder) -->
            <div id="page-organize" class="page-section" style="display:none">
                <div class="page-title">🏆 Tổ chức giải đấu</div>
                <p class="page-sub">Tạo và quản lý giải đấu của bạn</p>
                <div class="profile-card organize-card">
                    <div class="organize-section">
                        <h5>Thông tin cơ bản</h5>
                        <div class="organize-grid-two">
                            <div class="form-group-dark">
                                <label>Tên giải đấu</label>
                                <input class="form-control-dark" id="org-ten-giai" placeholder="Nhập tên giải đấu" />
                            </div>
                            <div class="form-group-dark">
                                <label>Game</label>
                                <select class="select-dark" id="org-game"></select>
                            </div>
                        </div>
                        <div class="organize-grid-two">
                            <div class="form-group-dark">
                                <label>Banner giải đấu</label>
                                <input class="form-control-dark" id="org-banner-file" type="file" accept="image/*" />
                                <small class="organize-helper">Ảnh gợi ý: JPG/PNG, tối đa 5MB.</small>
                            </div>
                            <div class="form-group-dark">
                                <label>Tổng giải thưởng (VNĐ)</label>
                                <input class="form-control-dark" id="org-giai-thuong" type="number" min="0" placeholder="0" readonly style="background:var(--bg-dark)" />
                                <small class="organize-helper">Tự động tính theo danh sách giải thưởng chi tiết.</small>
                            </div>
                        </div>
                        <div class="form-group-dark">
                            <label>Mô tả giải đấu</label>
                            <textarea class="form-control-dark" id="org-mo-ta" placeholder="Nhập mô tả giải đấu" rows="4"></textarea>
                        </div>
                    </div>

                    <div class="organize-section">
                        <h5>Giải thưởng</h5>
                        <div class="form-group-dark">
                            <label>Giải thưởng chi tiết (Tùy chọn)</label>
                            <div id="org-prizes-list" style="margin-bottom:10px"></div>
                            <button class="btn-outline-glow" onclick="addPrizeInput()">+ Thêm giải thưởng</button>
                        </div>
                    </div>

                    <div class="organize-section">
                        <h5>Thời gian</h5>
                        <div class="organize-grid-two organize-grid-time">
                            <div class="form-group-dark">
                                <label>Ngày bắt đầu</label>
                                <input class="form-control-dark" id="org-start" type="datetime-local" />
                            </div>
                            <div class="form-group-dark">
                                <label>Ngày kết thúc</label>
                                <input class="form-control-dark" id="org-end" type="datetime-local" />
                            </div>
                        </div>
                    </div>

                    <div class="organize-section">
                        <h5>Thiết lập giải</h5>
                        <div class="organize-grid-two">
                            <div class="form-group-dark">
                                <label>Số đội tối thiểu</label>
                                <input class="form-control-dark" id="org-so-doi-toi-thieu" type="number" min="2" placeholder="Tối thiểu 2" value="2" />
                            </div>
                            <div class="form-group-dark">
                                <label>Số đội tối đa (tùy chọn)</label>
                                <input class="form-control-dark" id="org-so-doi-toi-da" type="number" min="2" placeholder="Để trống nếu không giới hạn" />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="profile-card" style="margin-top:20px">
                    <h5>Thiết lập giai đoạn</h5>
                    <div style="max-height:300px;overflow-y:auto;border:1px solid var(--border-dark);border-radius:8px;padding:12px;margin-bottom:12px">
                        <table style="width:100%;border-collapse:collapse">
                            <thead>
                                <tr style="border-bottom:1px solid var(--border-dark)">
                                    <th style="text-align:left;padding:8px">Giai đoạn</th>
                                    <th style="text-align:left;padding:8px">Thể thức</th>
                                    <th style="text-align:left;padding:8px">Ngày bắt đầu</th>
                                    <th style="text-align:left;padding:8px">Ngày kết thúc</th>
                                    <th style="text-align:left;padding:8px">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody id="org-stages-list">
                                <tr id="stage-1">
                                    <td style="padding:8px">Giai đoạn 1</td>
                                    <td style="padding:8px">
                                        <select class="form-control-dark" id="stage-1-format">
                                            <option value="nhanh_thang_nhanh_thua">Nhánh thắng / Nhánh thua</option>
                                            <option value="vong_tron">Đấu vòng tròn</option>
                                            <option value="thuy_si">Hệ Thụy Sĩ (Swiss)</option>
                                            <option value="champion_rush">Champion Rush</option>
                                        </select>
                                    </td>
                                    <td style="padding:8px">
                                        <input class="form-control-dark organize-stage-datetime" id="stage-1-start" type="datetime-local" />
                                    </td>
                                    <td style="padding:8px">
                                        <input class="form-control-dark organize-stage-datetime" id="stage-1-end" type="datetime-local" />
                                    </td>
                                    <td style="padding:8px"></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <div style="display:flex;gap:10px;margin-top:10px">
                        <button class="btn-primary-glow" onclick="addStage()">+ Thêm giai đoạn</button>
                        <button class="btn-primary-glow" onclick="previewStages()">Xem trước</button>
                    </div>
                </div>

                <div id="stage-preview" style="margin-top:16px;padding:12px;background:var(--bg-dark);border-radius:8px;display:none"></div>

                <div style="margin-top:20px">
                    <button class="btn-save" onclick="submitOrganize()">Gửi yêu cầu</button>
                    <span id="org-msg" style="margin-left:12px;font-size:.85rem"></span>
                </div>
            </div>

            <!-- CREATE TEAM (placeholder) -->
            <div id="page-create-team" class="page-section" style="display:none">
                <div class="page-title">👥 Tạo đội</div>
                <p class="page-sub">Thành lập đội và tạo ít nhất 1 nhóm thi đấu</p>
                <div class="profile-card">
                    <h5>Thông tin đội</h5>
                    <div class="form-group-dark">
                        <label>Tên đội</label>
                        <input class="form-control-dark" id="team-ten" placeholder="Tên đội tuyển" />
                    </div>
                    <div class="form-group-dark">
                        <label>Tên viết tắt (Tag)</label>
                        <input class="form-control-dark" id="team-tag" placeholder="VD: FPT" maxlength="20" />
                    </div>
                    <div class="form-group-dark">
                        <label>Slogan</label>
                        <input class="form-control-dark" id="team-slogan" placeholder="Slogan đội" />
                    </div>
                    <div class="form-group-dark">
                        <label>Nhóm thi đấu (bắt buộc ít nhất 1)</label>
                        <div id="team-squads-container"></div>
                        <button class="btn-outline-glow" style="margin-top:8px;font-size:.85rem;padding:6px 12px" onclick="addSquadRow()">+ Thêm nhóm</button>
                    </div>
                    <button class="btn-save" onclick="submitCreateTeam()">Tạo đội</button>
                    <span id="team-msg" style="margin-left:12px;font-size:.85rem"></span>
                </div>
            </div>

            <!-- EDIT TEAM MODAL -->
            <div id="edit-team-modal" class="modal-overlay" style="display:none">
                <div class="modal-content">
                    <div class="modal-header">
                        <h3>✏️ Sửa thông tin đội</h3>
                        <button class="modal-close" onclick="closeEditTeamModal()">✕</button>
                    </div>
                    <div class="modal-body">
                        <div class="form-group-dark">
                            <label>Tên đội</label>
                            <input class="form-control-dark" id="edit-team-ten" />
                        </div>
                        <div class="form-group-dark">
                            <label>Tên viết tắt (Tag)</label>
                            <input class="form-control-dark" id="edit-team-tag" maxlength="20" />
                        </div>
                        <div class="form-group-dark">
                            <label>Slogan</label>
                            <input class="form-control-dark" id="edit-team-slogan" />
                        </div>
                        <div class="form-group-dark">
                            <label>Logo URL</label>
                            <input class="form-control-dark" id="edit-team-logo" />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button class="btn-outline-glow" onclick="closeEditTeamModal()">Hủy</button>
                        <button class="btn-primary-glow" onclick="submitEditTeam()">Lưu thay đổi</button>
                    </div>
                    <span id="edit-team-msg" style="display:block;margin-top:10px;font-size:.85rem"></span>
                </div>
            </div>

            <!-- PROFILE PAGE -->
            <div id="page-profile" class="page-section" style="display:none">
                <div class="page-title">👤 Thông tin cá nhân</div>
                <p class="page-sub">Quản lý thông tin tài khoản của bạn</p>
                <div class="profile-header">
                    <div class="profile-avatar-big" id="profile-avatar-big" onclick="triggerAvatarUpload()" title="Bấm để đổi ảnh đại diện" style="cursor:pointer;position:relative;overflow:hidden">
                        <span id="avatar-initials-big">?</span>
                        <img id="profile-avatar-img" src="" alt="" style="display:none;width:100%;height:100%;object-fit:cover;border-radius:50%;position:absolute;top:0;left:0" />
                        <div class="avatar-camera-overlay">📷</div>
                    </div>
                    <input type="file" id="avatar-file-input" accept="image/*" style="display:none" />
                    <div class="profile-info">
                        <h2 id="profile-username-display">-</h2>
                        <p id="profile-email-display">-</p>
                        <p style="color:var(--accent);font-size:.8rem;margin-top:4px" id="profile-role-display"></p>
                    </div>
                </div>
                <div class="profile-card">
                    <h5>Thông tin tài khoản</h5>
                    <div class="form-group-dark">
                        <label>Tên đăng nhập</label>
                        <input class="form-control-dark" id="pf-username" disabled />
                    </div>
                    <div class="form-group-dark">
                        <label>Email</label>
                        <input class="form-control-dark" id="pf-email" />
                    </div>
                    <div class="form-group-dark">
                        <label>Đội</label>
                        <input class="form-control-dark" id="pf-team" placeholder="Chưa tham gia đội nào" disabled />
                    </div>
                    <div class="form-group-dark">
                        <label>Giới thiệu bản thân</label>
                        <input class="form-control-dark" id="pf-bio" placeholder="Bio ngắn" />
                    </div>
                    <button class="btn-save" onclick="saveProfile()">Lưu thay đổi</button>
                    <span id="pf-msg" style="margin-left:12px;font-size:.85rem"></span>
                </div>
                <div class="profile-card">
                    <h5>🔒 Đổi mật khẩu</h5>
                    <div class="form-group-dark">
                        <label>Mật khẩu cũ</label>
                        <input class="form-control-dark" id="pw-old" type="password" placeholder="Nhập mật khẩu hiện tại" />
                    </div>
                    <div class="form-group-dark">
                        <label>Mật khẩu mới</label>
                        <input class="form-control-dark" id="pw-new" type="password" placeholder="Tối thiểu 8 ký tự" />
                    </div>
                    <div class="form-group-dark">
                        <label>Xác nhận mật khẩu mới</label>
                        <input class="form-control-dark" id="pw-confirm" type="password" placeholder="Nhập lại mật khẩu mới" />
                    </div>
                    <button class="btn-save" onclick="changePassword()">Đổi mật khẩu</button>
                    <span id="pw-msg" style="margin-left:12px;font-size:.85rem"></span>
                </div>
            </div>

            <!-- PLAYER PROFILE PAGE -->
            <div id="page-player-profile" class="page-section" style="display:none">
                <div class="page-title">🎮 Profile Player</div>
                <p class="page-sub">Tạo và quản lý hồ sơ trong game của bạn cho từng tựa game</p>
                <div class="game-profile-tabs" id="game-profile-tabs"></div>
                <div class="profile-card" id="game-profile-form-wrap">
                    <h5 id="game-profile-title">Chọn game để xem hồ sơ</h5>
                    <div id="game-profile-body">
                        <div class="empty-state" style="padding:30px">
                            <div class="empty-state-icon">🎮</div>
                            <h4>Chọn một game</h4>
                            <p>Bấm vào tab game ở trên để xem hoặc tạo hồ sơ.</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ADMIN REQUESTS -->
            <div id="page-admin-requests" class="page-section" style="display:none">
                <div class="page-title">⚙️ Yêu cầu Admin</div>
                <p class="page-sub">Phê duyệt hoặc từ chối yêu cầu tạo giải đấu</p>
                <div id="admin-request-list"></div>

                <div class="profile-card" style="margin-top:16px">
                    <h5>Quản trị mở quyền sửa kết quả</h5>
                    <form id="form-admin-load-unlock-requests" style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:12px">
                        <select class="select-dark" name="trangThai" style="min-width:180px">
                            <option value="">Tất cả trạng thái</option>
                            <option value="cho_duyet">Chờ duyệt</option>
                            <option value="da_duyet">Đã duyệt</option>
                            <option value="tu_choi">Từ chối</option>
                        </select>
                        <button class="btn-primary-glow" type="submit">Tải danh sách yêu cầu</button>
                    </form>
                    <div id="referee-unlock-request-list"></div>

                    <form id="form-admin-handle-unlock-request" style="margin-top:14px">
                        <div class="organize-grid-two">
                            <div class="form-group-dark">
                                <label>Mã yêu cầu</label>
                                <input class="form-control-dark" name="MaYeuCau" type="number" min="1" required />
                            </div>
                            <div class="form-group-dark">
                                <label>Hành động</label>
                                <select class="select-dark" name="ChapNhan">
                                    <option value="true">Duyệt mở quyền sửa</option>
                                    <option value="false">Từ chối</option>
                                </select>
                            </div>
                        </div>
                        <div class="organize-grid-two">
                            <div class="form-group-dark">
                                <label>Số giờ mở quyền sửa (khi duyệt)</label>
                                <input class="form-control-dark" name="SoGioMoKhoa" type="number" min="1" value="2" />
                            </div>
                            <div class="form-group-dark">
                                <label>Phản hồi admin</label>
                                <input class="form-control-dark" name="PhanHoiAdmin" placeholder="Lý do duyệt/từ chối" />
                            </div>
                        </div>
                        <button class="btn-save" type="submit">Xử lý yêu cầu</button>
                    </form>
                </div>
            </div>

            <div id="page-referee-center" class="page-section" style="display:none">
                <div class="page-title">🧑‍⚖️ Trung tâm Trọng tài</div>
                <p class="page-sub">Nhập kết quả, chỉnh sửa theo quyền mở khóa và theo dõi khiếu nại</p>

                <div class="profile-card" style="margin-bottom:16px">
                    <h5>Danh sách trận của tôi</h5>
                    <form id="form-referee-my-matches" style="display:flex;gap:8px;flex-wrap:wrap">
                        <select class="select-dark" name="tab" style="min-width:180px">
                            <option value="can_nhap_diem">Cần nhập điểm</option>
                            <option value="sap_dien_ra">Sắp diễn ra</option>
                            <option value="da_hoan_thanh">Đã hoàn thành</option>
                        </select>
                        <button class="btn-primary-glow" type="submit">Tải danh sách</button>
                    </form>
                    <div id="referee-match-list" style="margin-top:10px"></div>
                </div>

                <div class="profile-card" style="margin-bottom:16px">
                    <h5>Chi tiết trận và nhập kết quả</h5>
                    <form id="form-referee-load-match" style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:12px">
                        <input class="form-control-dark" style="max-width:220px" name="maTran" type="number" min="1" placeholder="Mã trận" required />
                        <button class="btn-primary-glow" type="submit">Tải chi tiết trận</button>
                    </form>
                    <input type="hidden" id="referee-ma-tran" value="0" />

                    <table id="referee-player-grid" class="tpub-table">
                        <thead>
                            <tr>
                                <th>Người chơi</th>
                                <th>K</th>
                                <th>D</th>
                                <th>A</th>
                                <th>Điểm sinh tồn</th>
                                <th>KDA</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>

                    <div class="form-group-dark" style="margin-top:12px">
                        <label>Lý do sửa (bắt buộc khi sửa)</label>
                        <input class="form-control-dark" id="referee-ly-do" placeholder="Nhập lý do khi chỉnh sửa kết quả" />
                    </div>

                    <div style="display:flex;gap:8px;flex-wrap:wrap">
                        <button class="btn-save" id="btn-referee-save" type="button">Nhập kết quả lần đầu</button>
                        <button class="btn-outline-glow" id="btn-referee-edit" type="button">Sửa kết quả</button>
                        <button class="btn-outline-glow" id="btn-admin-edit" type="button">Admin sửa trực tiếp</button>
                    </div>
                </div>

                <div class="profile-card" style="margin-bottom:16px">
                    <h5>Yêu cầu mở quyền sửa kết quả</h5>
                    <form id="form-referee-request-unlock">
                        <div class="organize-grid-two">
                            <div class="form-group-dark">
                                <label>Mã trận</label>
                                <input class="form-control-dark" name="MaTran" type="number" min="1" required />
                            </div>
                            <div class="form-group-dark">
                                <label>Lý do yêu cầu</label>
                                <input class="form-control-dark" name="LyDo" required placeholder="Nêu rõ lý do cần mở quyền sửa" />
                            </div>
                        </div>
                        <button class="btn-primary-glow" type="submit">Gửi yêu cầu mở khóa</button>
                    </form>
                </div>
            </div>
        </div><!-- /content-area -->
    </div><!-- /main-area -->

    <!-- Custom Confirmation Modal -->
    <div id="confirm-modal" class="custom-modal" style="display:none">
        <div class="modal-overlay" onclick="closeConfirmModal()"></div>
        <div class="modal-content">
            <div class="modal-header">
                <h3 id="modal-title">Xác nhận</h3>
            </div>
            <div class="modal-body">
                <p id="modal-message">Bạn có chắc chắn?</p>
            </div>
            <div class="modal-footer">
                <button class="btn-cancel" onclick="closeConfirmModal()">Hủy</button>
                <button class="btn-confirm" id="modal-confirm-btn">Đồng ý</button>
            </div>
        </div>
    </div>
</div><!-- /app-shell -->

<script src="~/Scripts/jquery-3.7.0.min.js"></script>
<script src="~/Scripts/app.js"></script>
<script src="~/Scripts/portal.js"></script>
</body>
</html>
